<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>
    <%= title%>
  </title>
  <% if (page==="home" ) { %>
    <link rel="preload" as="image" href="/assets/image/homeBgImage.avif" imagesrcset="/assets/image/homeBgImage.avif"
      imagesizes="100vw" fetchpriority="high">
    <% } %>

      <link rel="stylesheet" href="/tailwind-build.css">
      <style>
        /* Only remove list markers inside the main content area to avoid affecting header/nav */
        main ul,
        main ol,
        main li,
        main .list-disc,
        main .list-decimal,
        main .list-inside,
        main .list-outside {
          list-style: none !important;
          padding-left: 0 !important;
          margin-left: 0 !important;
        }

        /* Hide marker pseudo-element where supported inside main */
        main li::marker {
          content: '' !important;
          color: transparent !important;
          font-size: 0 !important;
        }
      </style>
</head>

<body class="bg-slate-50 text-slate-900 antialiased">
  <%- include('../partial/Header.ejs')%>

    <main>
      <%- body %>
    </main>

    <%- include('../partial/footer.ejs')%>

      <script src="/user/loading.js" defer></script>
      <!-- <script src="/user/Category.js" defer></script> -->

        <% if (title==="home" ) { %>
          <script src="/user/home.js" defer></script>
          <% } %>
        <% if (title==="blog-contant" ) { %>
       <script src="/user/blog-content.js" defer></script>
       <script src="/user/comments.js" defer></script>
         
          <% } %>
        <% if (page==="ArticleList" ) { %>
      
            <script src="/user/articleList.js" defer></script>
         
          <% } %>
      
          
          <!-- <script src="/user/Singup.js" defer></script> -->
        <!-- <script src="/user/chart.js" defer></script>-->
      

                      <script src="/user/navResponsive.js" defer></script>
                      <script src="/user/footer.js" defer></script>



</body>

</html>
