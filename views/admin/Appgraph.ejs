<!DOCTYPE html>
<html lang="en" >
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Blogs & Apps Stats Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-gray-100 max-w-5xl m-auto p-6 mr-1">

  <%-include("../../partial/sidebar.ejs")%>
  

  <div class="max-w-4xl mr-1 bg-white rounded-lg shadow-lg p-8">

    <h1 class="text-2xl font-bold mb-8 text-center">Applications Stats Dashboard</h1>

    <div class="grid grid-cols-1 gap-8">

  

      <!-- App Stats Chart -->
      <section>
        <h2 class="text-2xl font-semibold mb-4 text-center">App Downloads Over Last 7 Days</h2>
        <canvas id="appChart" class="max-w-full"></canvas>
      </section>

    </div>
  </div>

  <script>
   
    const appCtx = document.getElementById('appChart').getContext('2d');

    const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];



    // Sample App Downloads Data
    const appData = [80, 90, 100, 95, 110, 130, 160];

   

    // App Downloads Chart
    const appChart = new Chart(appCtx, {
      type: 'bar',
      data: {
        labels: days,
        datasets: [{
          label: 'App Downloads',
          data: appData,
          backgroundColor: '#16a34a'
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: true, position: 'top' }
        },
        scales: {
          y: { beginAtZero: true }
        }
      }
    });
  </script>
  
</body>
</html>
