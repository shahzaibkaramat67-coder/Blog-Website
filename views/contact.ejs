<div class="max-w-3xl mx-auto mt-6 bg-white rounded-lg shadow-lg p-8">
  <h1 class="text-3xl font-bold text-center mb-8 text-gray-800">Contact Us</h1>

  <form action="/contact/contact-form-submit" method="POST" class="space-y-5" autocomplete="off">

    <div>
      <label for="name" class="block text-sm font-medium text-gray-700">Name</label>
      <input type="text" 
             id="name" 
             name="name" 
             required 
             maxlength="50" 
             pattern="[A-Za-z\s]+" 
             class="w-full mt-1 p-3 border border-gray-300 rounded-md focus:ring focus:ring-green-200"
             placeholder="John Doe" />
    </div>

    <div>
      <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
      <input type="email" 
             id="email" 
             name="email" 
             required 
             maxlength="100"
             class="w-full mt-1 p-3 border border-gray-300 rounded-md focus:ring focus:ring-green-200"
             placeholder="example@gmail.com" />
    </div>

    <div>
      <label for="subject" class="block text-sm font-medium text-gray-700">Subject</label>
      <input type="text" 
             id="subject" 
             name="subject" 
             required 
             maxlength="100"
             class="w-full mt-1 p-3 border border-gray-300 rounded-md focus:ring focus:ring-green-200"
             placeholder="Enter your subject" />
    </div>

    <div>
      <label for="message" class="block text-sm font-medium text-gray-700">Message</label>
      <textarea id="message" 
                name="message"
                rows="5"
                required
                maxlength="1000"
                class="w-full mt-1 p-3 border border-gray-300 rounded-md focus:ring focus:ring-green-200"
                placeholder="Write your message here..."></textarea>
    </div>

    <button type="submit"
      class="bg-green-600 text-white py-3 px-6 rounded-md hover:bg-green-700 transition duration-200 w-full md:w-auto">
      Send Message
    </button>
  </form>
</div>
