 <%- include("../partial/Flash_response.ejs") %>

  <section class="min-h-screen bg-slate-50 flex items-center justify-center px-6 py-12">
    <div class="w-full max-w-md">
      <div class="bg-white rounded-3xl shadow-xl ring-1 ring-black/5 p-8 sm:p-10">
        <p class="text-xs uppercase tracking-widest text-slate-400">Account</p>
        <h1 class="mt-2 text-2xl font-semibold text-slate-900">Forgot Password</h1>
        <p class="mt-2 text-sm text-slate-500">Enter your username or email and we’ll send password reset instructions.</p>
        <form action="/submit-forgetPassword" method="POST" class="space-y-4">
          <div>
            <label for="identifier" class="block text-sm font-medium text-slate-700">Username or Email</label>
            <input type="text" id="identifier" name="identifier" class="mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200" placeholder="username or email">
          </div>

          <div>
            <button type="submit" class="cursor-pointer w-full rounded-xl bg-teal-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-700">Send reset link</button>
          </div>
        </form>
      </div>
    </div>
  </section>