 <section  class="bg-gray-50 text-gray-800">
     <header class="bg-white shadow">
    <div class="max-w-screen-xl mx-auto px-6 py-4">
      <h1 class="text-3xl font-bold text-teal-600">Help Center</h1>
      <p class="mt-2 text-gray-600">Find answers and support for all your questions.</p>
    </div>
  </header>

  <main class="max-w-screen-xl mx-auto px-6 py-10">
    <section class="grid md:grid-cols-3 gap-8">

      <div class="bg-white p-6 rounded-lg shadow hover:shadow-lg transition">
        <h2 class="text-xl font-semibold text-gray-900 mb-2">Getting Started</h2>
        <p class="text-gray-600">Learn how to set up your account, create your first blog post, and manage your profile.</p>
        <a href="/help/getting-started" class="mt-4 inline-block text-teal-600 hover:underline">Learn More →</a>
      </div>

      <div class="bg-white p-6 rounded-lg shadow hover:shadow-lg transition">
        <h2 class="text-xl font-semibold text-gray-900 mb-2">Publishing & Content</h2>
        <p class="text-gray-600">Understand our platform rules, content guidelines, and how to optimize your posts.</p>
        <a href="/help/publishing" class="mt-4 inline-block text-teal-600 hover:underline">Learn More →</a>
      </div>

      <div class="bg-white p-6 rounded-lg shadow hover:shadow-lg transition">
        <h2 class="text-xl font-semibold text-gray-900 mb-2">Payments & Earnings</h2>
        <p class="text-gray-600">How to track your earnings, withdraw funds, and manage your financial settings.</p>
        <a href="/help/payments" class="mt-4 inline-block text-teal-600 hover:underline">Learn More →</a>
      </div>

    </section>
  </main>

  <footer class="bg-gray-100 py-6 mt-12">
    <div class="max-w-screen-xl mx-auto text-center text-sm text-gray-500">
      © <%= new Date().getFullYear() %> BlogHub. All rights reserved.
    </div>
  </footer>
 </section>

