  <section class="bg-gray-50 text-gray-800">
      <header class="bg-white shadow">
    <div class="max-w-screen-xl mx-auto px-6 py-4">
      <h1 class="text-3xl font-bold text-teal-600">Contact Us</h1>
      <p class="mt-2 text-gray-600">We’d love to hear from you. Send us a message and we’ll get back to you soon.</p>
    </div>
  </header>

  <main class="max-w-screen-md mx-auto px-6 py-10">
    <form class="bg-white p-8 rounded-lg shadow space-y-6" action="/contact" method="POST">
      <div>
        <label class="block text-gray-700 font-medium mb-2" for="name">Name</label>
        <input class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-teal-500 focus:border-teal-500" type="text" id="name" name="name" required>
      </div>

      <div>
        <label class="block text-gray-700 font-medium mb-2" for="email">Email</label>
        <input class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-teal-500 focus:border-teal-500" type="email" id="email" name="email" required>
      </div>

      <div>
        <label class="block text-gray-700 font-medium mb-2" for="message">Message</label>
        <textarea class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-teal-500 focus:border-teal-500" id="message" name="message" rows="6" required></textarea>
      </div>

      <button type="submit" class="bg-teal-600 text-white px-6 py-2 rounded hover:bg-teal-700 transition">Send Message</button>
    </form>
  </main>

  <footer class="bg-gray-100 py-6 mt-12">
    <div class="max-w-screen-xl mx-auto text-center text-sm text-gray-500">
      © <%= new Date().getFullYear() %> BlogHub. All rights reserved.
    </div>
  </footer>
  </section>

