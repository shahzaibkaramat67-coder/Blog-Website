<section class="max-w-6xl mx-auto px-6 py-16">

  <h1 class="text-4xl font-bold text-gray-900 mb-8 text-center">Latest Updates</h1>

  <div id="updatesContainer" class="space-y-6">
    <% updates.forEach((update) => { %>
      <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">
        <h3 class="text-xl font-semibold mb-3
          <%= update.category === 'feature' ? 'text-teal-600' : 
              update.category === 'announcement' ? 'text-blue-600' : 
              'text-gray-700' %>">
          <%= update.title %>
        </h3>

        <p class="text-gray-700 mb-4"><%= update.description %></p>

        <div class="flex justify-between items-center text-sm text-gray-500">
          <span>Posted on <%= new Date(update.createdAt).toLocaleDateString() %></span>
          <span class="px-2 py-1 rounded-full
            <%= update.category === 'feature' ? 'bg-teal-100 text-teal-600' : 
                update.category === 'announcement' ? 'bg-blue-100 text-blue-600' : 
                'bg-gray-100 text-gray-700' %>">
            <%= update.category.charAt(0).toUpperCase() + update.category.slice(1) %>
          </span>
        </div>
      </div>
    <% }) %>
  </div>

</section>