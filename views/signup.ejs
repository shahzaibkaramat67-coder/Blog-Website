  <%- include("../partial/Flash_response.ejs") %>

    <section class="min-h-screen bg-slate-50 flex items-center py-12">
      <div class="max-w-5xl mx-auto w-full p-6">
        <div class="grid gap-8 lg:grid-cols-2 items-stretch">
          <div class="rounded-3xl bg-linear-to-br from-slate-900 via-slate-800 to-teal-700 p-10 text-white shadow-2xl">
            <p class="text-xs uppercase tracking-widest text-white/70">Join BlogHub</p>
            <h1 class="mt-3 text-4xl font-semibold leading-tight">Create your account</h1>
            <p class="mt-4 text-white/75">
              Publish with confidence, build your profile, and connect with a growing community of readers.
            </p>
            <div class="mt-8 grid gap-3 text-sm text-white/80">
              <div class="flex items-center gap-2">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10">✓</span>
                Your own creator dashboard
              </div>
              <div class="flex items-center gap-2">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10">✓</span>
                Earn with every published article
              </div>
              <div class="flex items-center gap-2">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10">✓</span>
                Secure sign-in and account tools
              </div>
            </div>
          </div>
          <div class="rounded-3xl bg-white shadow-xl ring-1 ring-black/5 p-8 sm:p-10">
            <form action="/submit-singup" method="POST" class="space-y-5">
              <!-- <div class="form_date">
            <label for="firstName">Username</label>
            <input type="text" id="firstName" name="firstName">
            <p id="firstNameError" class="text-[2px] mt-1 text-red-500"></p>
          </div> -->
              <div class="form_date">
                <label for="Username" class="block text-sm font-medium text-slate-700">Username</label>
                <input type="text" id="Username" name="Username" required
                  class="mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200"
                  placeholder="Choose a username">
                <p id="UsernameError" class="text-sm mt-1 text-red-500"></p>
              </div>
              <div class="form_date">
                <label for="email" class="block text-sm font-medium text-slate-700">Email</label>
                <input type="email" id="email" name="Email" required
                  class="mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200"
                  placeholder="you@example.com">
                <p id="emailError" class="text-sm mt-1 text-red-500"></p>
              </div>
              <div class="form_date relative">
                <label for="password" class="block text-sm font-medium text-slate-700">Password</label>
                <input type="password" id="password" name="password" required
                  class="mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200"
                  placeholder="Choose a strong password">
                <p id="passwordError" class="text-sm mt-1 text-red-500"></p>
                <span class="absolute right-3 w-5 top-10 inline-block">
                  <img src="/assets/icons/eye-slash-solid-full.svg" class="toggle-password cursor-pointer"
                    toggle="password" alt="toggle">
                </span>
              </div>
              <div class="form_date relative">
                <label for="confirmPassword" class="block text-sm font-medium text-slate-700">Confirm Password</label>
                <input type="password" id="confirmPassword" name="confirmPassword" required
                  class="mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200"
                  placeholder="Repeat password">
                <p id="confirmPasswordError" class="text-sm mt-1 text-red-500"></p>
                <span class="absolute right-3 w-5 top-10 inline-block">
                  <img src="/assets/icons/eye-slash-solid-full.svg" class="toggle-password cursor-pointer"
                    toggle="confirmPassword" alt="toggle">
                </span>
              </div>
              <div class="form_date">
                <button type="submit"
                  class="w-full cursor-pointer rounded-xl bg-teal-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-700">Create
                  account</button>
              </div>
              <div>
                <p class="text-sm  text-slate-500">If you already have an account, <a href="/login" class="font-medium cursor-pointer text-teal-700 hover:text-teal-800">Login</a>.</p>
              </div>

              <div>
                <div class="flex items-center justify-center gap-3">
                   <hr class="grow border-slate-200">
                   <span class="text-xs font-semibold uppercase tracking-widest text-slate-400">OR</span>
                  <hr class="grow border-slate-200">
                </div>
                <div class="singup_option flex gap-3 justify-center">
                  <a href="/auth/google" class="p-2 cursor-pointer rounded-xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow">
                    <img src="/assets/icons/google-brands-solid-full.svg" alt="G" class="w-1 h-1">
                  </a>
                  <a href="/auth/facebook" class="p-2 cursor-pointer rounded-xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow">
                    <img src="/assets/icons/facebook-brands-solid-full.svg" alt="F" class="w-1 h-1">
                  </a>
                  <!-- <a href="">N</a> -->
                </div>
              </div>
            </form>

          </div>
        </div>
    </section>