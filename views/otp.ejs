<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OTP Verification</title>
  <link rel="stylesheet" href="/tailwind-build.css">
  <!-- <link rel="stylesheet" href="/all.css"> -->
</head>

<body class="bg-slate-50 flex items-center justify-center min-h-screen px-6 py-12">

  <div class="bg-white shadow-xl ring-1 ring-black/5 rounded-3xl p-8 sm:p-10 w-full max-w-md">
    <p class="text-xs uppercase tracking-widest text-slate-400 text-center">Security</p>
    <h2 class="mt-2 text-2xl font-semibold text-center text-slate-900">Verify Your OTP</h2>
    <p class="mt-2 text-slate-500 text-center mb-8">Enter the 6-digit code sent to your email</p>

    <form class="otpForm" action="/otp-submit" method="post" class="space-y-6">
      <div class="flex justify-between gap-3">
        <input type="text" maxlength="1" autofocus
          class="otp-digit w-14 h-14 text-center rounded-xl border border-slate-200 bg-white text-2xl shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200" />
        <input type="text" maxlength="1"
          class="otp-digit w-14 h-14 text-center rounded-xl border border-slate-200 bg-white text-2xl shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200" />
        <input type="text" maxlength="1"
          class="otp-digit w-14 h-14 text-center rounded-xl border border-slate-200 bg-white text-2xl shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200" />
        <input type="text" maxlength="1"
          class="otp-digit w-14 h-14 text-center rounded-xl border border-slate-200 bg-white text-2xl shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200" />
        <input type="text" maxlength="1"
          class="otp-digit w-14 h-14 text-center rounded-xl border border-slate-200 bg-white text-2xl shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200" />
        <input type="text" maxlength="1"
          class="otp-digit w-14 h-14 text-center rounded-xl border border-slate-200 bg-white text-2xl shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200" />
      </div>

      <input type="hidden" name="otp" id="otpInput">

      <button type="submit"
        class="w-full rounded-xl bg-teal-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-700">
        Verify OTP
      </button>
    </form>

    <div class="text-center mt-5 text-sm text-slate-500">
      Didn't receive the code?
      <a href="#" class="font-medium text-teal-700 hover:text-teal-800">Resend</a>
    </div>
  </div>



  <script src="/user/opt.js" defer></script>


</body>

</html>
