<main class="flex-1 p-6">
        <h1 class="text-2xl font-semibold mb-5">Admin Settings</h1>

        <form class="bg-white p-6 rounded shadow w-full max-w-lg">
            <label class="block mb-3">
                <span class="text-gray-700">Change Password</span>
                <input type="password" class="mt-1 w-full px-3 py-2 border rounded" placeholder="New Password" />
            </label>

            <label class="block mb-3">
                <span class="text-gray-700">Confirm Password</span>
                <input type="password" class="mt-1 w-full px-3 py-2 border rounded" placeholder="Confirm Password" />
            </label>

            <button class="bg-indigo-600 text-white px-4 py-2 rounded mt-3">Update</button>
        </form>

    </main>