              <td class="px-6 py-4">
                <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs font-semibold">
                  Low
                </span>
              </td>
              <td class="px-6 py-4">$3</td>
              <td class="px-6 py-4 text-red-600 font-semibold">Inactive</td>
            </tr> -->
          </tbody>
        </table>
      </div>
    </div>

    <!-- FORM -->
    <section id="formBox" class="bg-white rounded-2xl shadow p-8 max-w-xl mx-auto">
      <h2 class="text-2xl font-bold mb-6 text-center text-gray-800">
        Add / Update RPM Group
      </h2>

      <form action="/api/admin-RPM/submit" method="POST" class="space-y-5">

        <div>
          <label class="block mb-1 font-medium text-gray-700">RPM Level</label>
          <select name="name" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-400">
            <option value="" disabled selected >select Option</option>
            <option value="High">High</option>
            <option value="Medium">Medium</option>
            <option value="Normal">Normal</option>
            <option value="Low">Low</option>
          </select>
        </div>

        <div>
          <label class="block mb-1 font-medium text-gray-700">
            Rate per 1000 Views ($)
          </label>
          <input type="number" step="0.01" name="rate"
            placeholder="Example: 3.50"
            class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-400">
        </div>

        <div>
          <label class="block mb-1 font-medium text-gray-700">Status</label>
          <select name="status" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-400">
            <option value="" disabled selected >Select Status</option>
            <option value="Active">Active</option>
            <option value="Inactive">Inactive</option>
          </select>
        </div>

        <button
          class="w-full bg-blue-600 text-white py-2 rounded-xl hover:bg-blue-700 font-semibold">
          Save RPM Group
        </button>
      </form>
    </section>

  </div>