 <div class="max-w-5xl mx-auto space-y-8 mr-0">

    <!-- PAGE TITLE -->
    <div class="flex justify-between items-center">
      <h1 class="text-3xl font-bold text-gray-800">RPM Management</h1>
      <button onclick="document.getElementById('formBox').scrollIntoView({behavior:'smooth'})"
        class="bg-blue-600 text-white px-5 py-2 rounded-xl shadow hover:bg-blue-700">
        + Add RPM
      </button>
    </div>

    <!-- RPM TABLE -->
    <div class="bg-white rounded-2xl shadow overflow-hidden">
      <div class="px-6 py-4 border-b font-semibold text-gray-700">
        RPM Groups
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-100 text-gray-600 uppercase text-xs">
            <tr>
              <th class="px-6 py-3 text-left">RPM Level</th>
              <th class="px-6 py-3 text-left">Price / 1000 Views</th>
              <th class="px-6 py-3 text-left">Status</th>
            </tr>
          </thead>

          <tbody class="divide-y">

       <% if (allRpmData && allRpmData.length > 0) { %>

  <% allRpmData.forEach(rpm => { %>

    <tr class="hover:bg-gray-50">
      <td class="px-6 py-4">
        <span class=" px-3 py-1 rounded-full text-xs font-semibold <%= rpm.name === 'High' ? 'bg-green-100 text-green-700' : rpm.name === 'Medium' ? 'bg-blue-100 text-blue-700' : rpm.name === 'Normal' ? 'bg-yellow-100 text-yellow-700' :  'bg-red-100 text-red-700'%>">
          <%= rpm.name  %>
        </span>
      </td>

      <td class="px-6 py-4">$<%= rpm.rate_per_1000 %></td>

      <td class="px-6 py-4  font-semibold <%=  rpm.status === 'Active' ? 'text-green-600' : 'text-red-600'%>">
        <%= rpm.status %>
      </td>
    </tr>

  <% }); %>

<% } else { %>
  <tr>
    <td colspan="3" class="text-center py-6 text-gray-500">
      No data yet
    </td>
  </tr>
<% } %>


