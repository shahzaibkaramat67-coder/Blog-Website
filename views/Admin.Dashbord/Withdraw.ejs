<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin - Earnings</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 ">

    <!-- ADMIN HEADER -->
    <%- include("../../partial/AdminHeader.ejs") %>

        <main class="md:ml-64 flex-1 p-6">

            <!-- PAGE TITLE -->
            <h1 class="text-3xl font-bold mb-6 text-gray-800">Earnings Overview</h1>

            <!-- STAT CARDS -->
           

            <!-- Earnings Chart -->
           

            <!-- VENDOR EARNINGS TABLE -->
            <section class="bg-white p-6 rounded-xl shadow">
                <h2 class="text-xl font-bold mb-4">Withdrawal Requests</h2>

                <div class="mb-4 flex justify-between items-center">
                    <div>
                        <input type="text" placeholder="Search withdrawals..." class="px-3 py-2 rounded border w-3/3" />
                        <!-- <button class="px-4 py-2 bg-green-600 text-white rounded">Process Selected</button> -->
                    </div>
                    <div class="text-center flex gap-4 cursor-pointer">
                        <div>
                            <p class="text-gray-500">Pending</p>
                            <span class="font-bold text-gray-800">
                                <%= pending%>
                            </span>
                        </div>
                        <div>
                            <p class="text-gray-500">Approve</p>
                            <span class="font-bold text-gray-800">
                               <%= Approve%>
                            </span>
                        </div>
                        <div>
                            <p class="text-gray-500">Total</p>
                            <span class="font-bold text-gray-800">
                                <%= Total%>
                            </span>
                        </div>
                    </div>
                </div>

                <table class="w-full text-left border-collapse">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="py-3 px-2 border-b">Vendor Name</th>
                            <th class="py-3 px-2 border-b">Email</th>
                            <th class="py-3 px-2 border-b">Amount</th>
                            <th class="py-3 px-2 border-b">Status</th>
                            <th class="py-3 px-2 border-b">Requested Date</th>
                            <th class="py-3 px-2 border-b">Processed Date</th>
                            <th class="py-3 px-2 border-b">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-700">
                       <% if (withdrawList && withdrawList.length > 0) { %>
                      <% withdrawList.forEach(withdraw => { %>
                        
                         <tr class="border-b">
                            <td class="py-2 px-2"><%= withdraw.username%></td>
                            <td class="py-2 px-2"><%= withdraw.email%></td>
                            <td class="py-2 px-2"><span class="text-yellow-600 font-semibold">$<%= withdraw.amount%></span></td>
                            <td class="py-2 px-2"><%= withdraw.status%></td>
                            <td class="py-2 px-2"><%= withdraw.createdAt.toDateString()%></td>
                            <td class="py-2 px-2"><%= withdraw.method%></td>
                            <td class="py-2 px-2">
                                <button data-id="<%= withdraw._id%>" data-action="approve" class="withdraw-btn px-2 py-1 bg-green-600 text-white rounded text-sm">Approve</button>
                                <button data-id="<%= withdraw._id%>" data-action="decline" class="withdraw-btn px-2 py-1 bg-red-600 text-white rounded text-sm">Decline</button>
                            </td>
                        </tr>

                     <% }); %>
                     <% } else { %>
                        <h1 class="m-auto">No Withdrawal Request Yet</h1>
                      <% } %>
                    </tbody>
                </table>
            </section>

        </main>

<script>
document.addEventListener("click", async (e) => {
  if (!e.target.classList.contains("withdraw-btn")) return;

  const requestId = e.target.dataset.id;
  const action = e.target.dataset.action;

  console.log(requestId);
  console.log(action);
  

  if (!confirm(`Are you sure you want to ${action} this withdrawal?`)) return;

  try {
    const response = await fetch(`/api/admin-withdraw/withdraw/${requestId}/${action}`, {
      method: "POST",
      credentials: "include"
    });

    const data = await response.json();

    console.log(data);
    

    // if (!response.ok) {
    //   throw new Error(data.message || "Request failed");
    // }

    alert(data.message);
    location.reload();
  } catch (err) {
    alert(err.message);
    console.error(err);
  }
});
</script>

</body>

</html>