<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin - Withdraw Earnings</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 ">

    <!-- ADMIN HEADER -->
    <%- include("../../partial/AdminHeader.ejs") %>

    <main class="md:ml-64 flex-1 p-6">

        <!-- PAGE TITLE -->
        <h1 class="text-3xl font-bold mb-6 text-gray-800">Withdraw Earnings</h1>

        <!-- AVAILABLE BALANCE CARD -->
        <div class="bg-white p-6 rounded-lg shadow mb-8">
            <h2 class="text-xl font-semibold mb-4">Available Balance</h2>
            <p class="text-3xl font-bold text-green-600">$4,250</p>
            <p class="text-gray-500 mt-1">This is your current balance available for withdrawal.</p>
        </div>

        <!-- WITHDRAW REQUEST FORM -->
        <div class="bg-white p-6 rounded-lg shadow mb-8">
            <h2 class="text-xl font-semibold mb-4">Request Withdrawal</h2>

            <form class="space-y-4">
                <div>
                    <label class="block text-gray-700 mb-1">Amount</label>
                    <input type="number" placeholder="$0" class="w-full px-4 py-2 border rounded" />
                </div>

                <div>
                    <label class="block text-gray-700 mb-1">Withdrawal Method</label>
                    <select class="w-full px-4 py-2 border rounded">
                        <option>Bank Transfer</option>
                        <option>PayPal</option>
                        <option>Crypto Wallet</option>
                    </select>
                </div>

                <div>
                    <label class="block text-gray-700 mb-1">Account Details</label>
                    <input type="text" placeholder="Enter account or wallet info" class="w-full px-4 py-2 border rounded" />
                </div>

                <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition">Request Withdraw</button>
            </form>
        </div>

        <!-- WITHDRAWAL HISTORY -->
        <section class="bg-white p-6 rounded-lg shadow">
            <h2 class="text-xl font-semibold mb-4">Withdrawal History</h2>

            <table class="w-full text-left border-collapse">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="py-3 px-2 border-b">Amount</th>
                        <th class="py-3 px-2 border-b">Method</th>
                        <th class="py-3 px-2 border-b">Account Info</th>
                        <th class="py-3 px-2 border-b">Status</th>
                        <th class="py-3 px-2 border-b">Requested Date</th>
                        <th class="py-3 px-2 border-b">Processed Date</th>
                    </tr>
                </thead>
                <tbody class="text-gray-700">
                    <tr class="border-b">
                        <td class="py-2 px-2">$500</td>
                        <td>Bank Transfer</td>
                        <td>XXXX-XXXX-XXXX-1234</td>
                        <td><span class="text-yellow-600 font-semibold">Pending</span></td>
                        <td>2025-11-20</td>
                        <td>-</td>
                    </tr>
                    <tr class="border-b">
                        <td class="py-2 px-2">$1,000</td>
                        <td>PayPal</td>
                        <td>admin@example.com</td>
                        <td><span class="text-green-600 font-semibold">Completed</span></td>
                        <td>2025-11-10</td>
                        <td>2025-11-12</td>
                    </tr>
                    <tr>
                        <td class="py-2 px-2">$750</td>
                        <td>Crypto Wallet</td>
                        <td>0xAbC123456789</td>
                        <td><span class="text-green-600 font-semibold">Completed</span></td>
                        <td>2025-11-05</td>
                        <td>2025-11-06</td>
                    </tr>
                </tbody>
            </table>
        </section>

    </main>

</body>
</html>
