<section class="max-w-3xl mx-auto px-6 py-16">


  <h1 class="text-4xl font-bold text-gray-900 mb-8 text-center">Post a New Update</h1>

  <!-- Update Form -->
  <form id="updateForm" class="bg-white p-6 rounded-xl shadow space-y-4">

    <!-- Title -->
    <div>
      <label class="block mb-1 font-semibold text-gray-700">Update Title</label>
      <input 
        type="text" 
        name="title" 
        id="title"
        placeholder="Enter your update title" 
        class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-teal-500" 
        required
      />
    </div>

    <!-- Description -->
    <div>
      <label class="block mb-1 font-semibold text-gray-700">Description</label>
      <textarea 
        name="description" 
        id="textarea"
        placeholder="Write the update details here..." 
        class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-teal-500" 
        rows="5"
        required
      ></textarea>
    </div>

    <!-- Category -->
    <div>
      <label class="block mb-1 font-semibold text-gray-700">Category</label>
      <select 
        name="category" 
        id="category"
        class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-teal-500"
      >
        <option value="announcement">Announcement</option>
        <option value="feature">Feature</option>
        <option value="maintenance">Maintenance</option>
      </select>
    </div>

    <!-- Submit Button -->
    <button 
      type="submit"
      id="update" 
      class="bg-teal-600 text-white px-6 py-2 rounded-lg hover:bg-teal-700 transition"
    >
      Post Update
    </button>

  </form>

  <!-- Status Message -->
  <p id="status" class="mt-4 text-gray-600"></p>

</section>


