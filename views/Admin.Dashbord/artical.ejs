<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

    <%- include("../../partial/AdminHeader.ejs") %>

    <main class="md:ml-64 flex-1 p-6">

        <!-- PAGE TITLE -->
        <h1 class="text-3xl font-bold mb-6 text-gray-800">Blog Categories</h1>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            <% allArticalCategories.forEach(cat => { %>
            <div class="bg-white rounded-lg shadow p-5 flex flex-col">
                <!-- CATEGORY NAME -->
                <h2 class="text-xl font-semibold text-gray-700 mb-4 border-b pb-2">
                    <%= cat.name %>
                </h2>

                <!-- TOPICS -->
                <div class="flex flex-col gap-3">
                    <% cat.topics.forEach(topic => { %>
                    <div class="border p-3 rounded-md flex items-center justify-between hover:bg-gray-50 transition">
                        <p class="text-gray-700 font-medium"><%= topic.title %></p>
                        <span class="bg-blue-100 text-blue-600 px-3 py-1 rounded-full text-sm font-bold">
                            <%= topic.count || 0 %>
                        </span>
                    </div>
                    <% }) %>
                </div>
            </div>
            <% }) %>

        </div>

    </main>

</body>

</html>
