<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

    <%- include("../../partial/AdminHeader.ejs") %>

    <main class="md:ml-64 flex-1 p-6">

        <h1 class="text-3xl font-bold mb-8 text-gray-800 tracking-wide">
            Blog Categories
        </h1>

        <!-- FIRST ROW (3 columns) -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
            <% finalstage.forEach(cat => { %>
            <div class="bg-white shadow-lg rounded-xl p-6 border border-gray-100 hover:shadow-xl transition">
                <h2 class="text-xl font-semibold text-gray-900 border-b pb-3 mb-4">
                    <%= cat.name %>
                </h2>
                <div class="flex flex-col gap-3">
                    <% cat.topics.forEach(topic => { %>
                    <div class="flex items-center justify-between px-4 py-2 rounded-lg bg-gray-50 hover:bg-blue-50 border border-gray-200 transition-all">
                        <span class="text-gray-700 font-medium"><%= topic.title %></span>
                        <span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-700 font-semibold"><%= topic.articleCount %></span>
                    </div>
                    <% }) %>
                </div>
            </div>
            <% }) %>
        </div>

      
    </main>

</body>

</html>
