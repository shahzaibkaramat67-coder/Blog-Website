<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin - Earnings</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 ">

    <!-- ADMIN HEADER -->
    <%- include("../../partial/AdminHeader.ejs") %>

        <main class="md:ml-64 flex-1 p-6">

            <!-- PAGE TITLE -->
            <h1 class="text-3xl font-bold mb-6 text-gray-800">Earnings Overview</h1>

            <!-- STAT CARDS -->
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">

                <!-- Total Earnings -->
                <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                    <h3 class="text-lg font-semibold mb-3">💰 Total Earnings</h3>
                    <p class="text-2xl font-bold">$12,450</p>
                </div>

                <!-- This Month -->
                <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                    <h3 class="text-lg font-semibold mb-3">📅 This Month</h3>
                    <p class="text-2xl font-bold">$2,450</p>
                </div>

                <!-- Today -->
                <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                    <h3 class="text-lg font-semibold mb-3">📈 Today</h3>
                    <p class="text-2xl font-bold">$245</p>
                </div>

                <!-- Pending Withdrawals -->
                <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                    <h3 class="text-lg font-semibold mb-3">⏳ Pending Withdrawals</h3>
                    <p class="text-2xl font-bold">$1,200</p>
                </div>
            </div>

            <!-- Earnings Chart -->
            <section class="bg-white p-6 rounded-xl shadow mb-8">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-bold">Earnings Trend</h2>
                    <select class="border border-gray-300 px-3 py-2 rounded">
                        <option>Last 7 Days</option>
                        <option>Last 15 Days</option>
                        <option>Last 1 Month</option>
                        <option>Last 3 Months</option>
                    </select>
                </div>
                <div class="bg-gray-50 h-64 flex items-center justify-center rounded text-gray-400">
                    Chart Placeholder
                </div>
            </section>

        

        </main>

</body>

</html>