<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin - Earnings</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 ">

    <!-- ADMIN HEADER -->
    <%- include("../../partial/AdminHeader.ejs") %>

        <main class="md:ml-64 flex-1 p-6">

            <!-- PAGE TITLE -->
            <h1 class="text-3xl font-bold mb-6 text-gray-800">Earnings Overview</h1>

            <!-- STAT CARDS -->
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">

                <!-- Total Earnings -->
                <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                    <h3 class="text-lg font-semibold mb-3">💰 Total Earnings</h3>
                    <p class="text-2xl font-bold"><%= total%></p>
                </div>

                <!-- This Month -->
                <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                    <h3 class="text-lg font-semibold mb-3">📅 This Month</h3>
                    <p class="text-2xl font-bold"><%= month%></p>
                </div>

                <!-- Today -->
                <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                    <h3 class="text-lg font-semibold mb-3">📈 Today</h3>
                    <p class="text-2xl font-bold"><%= day%></p>
                </div>

                <!-- Pending Withdrawals -->
                <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                    <h3 class="text-lg font-semibold mb-3">⏳ Pending Withdrawals</h3>
                    <p class="text-2xl font-bold"><%= balance%></p>
                </div>
            </div>

            <!-- Earnings Chart -->
            <section class="bg-white p-6 rounded-xl shadow mb-8">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-bold">Earnings Trend</h2>
                    <select id="selectRange" class="border border-gray-300 px-3 py-2 rounded">
                        <option value="7">Last 7 Days</option>
                        <option value="15">Last 15 Days</option>
                        <option value="30">Last 1 Month</option>
                        <option value="90">Last 3 Months</option>
                    </select>
                </div>
                <div id="Chart" class="bg-gray-50 h-90 flex items-center justify-center rounded">
                  <canvas id="chartTrend" width="600" height="400"></canvas>

                </div>
            </section>

        

        </main>



        <script>

        let chart
        const chartCtx = document.getElementById("chartTrend").getContext("2d")
        function renderChart(chart) {
            if (chart) chart.distroy();
           
            chart = new Chart(chartCtx, {
                type : "line",
                data : {
                    labels : data.labels,
                    dataset :[
                        {
                            labels : "Earning",
                            data : data.earning,
                            borderWidth : 2,
                            tension : 0.4
                        }
                    ]
                },
                options :{
                    responsive : true,
                    maintainAspectRatio : false,
                    Plugin :{
                        legend : {position : "top"}
                    },
                    scales: {
                y: { beginAtZero: true }
            }
                }
        

            })
        }

        async function loadChart(days = 7) {

            const res = await fetch(`/Api/admin-earning/chart-data?days=${days}`)
            console.log("res", res);

            if (!res.ok) {
                console.error("Failed to fetch chart data");
        return; 
                
            }

            const data = await res.json()
            renderChart(data)
        }
        loadChart()

  document.getElementById("selectRange").addEventListener("change", ()=>{
    loadChart(this.value)
  })


        </script>


</body>

</html>