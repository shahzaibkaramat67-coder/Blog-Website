<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Inbox</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 font-sans">

    <!-- Include Admin Header -->
    <%- include("../../partial/AdminHeader.ejs") %>

    <main class="md:ml-64 flex-1 p-6">

        <!-- Stats Bar -->
        <div class="flex items-center justify-between bg-white p-8 mb-5 rounded shadow-md">
            <div>
                <h1 class="text-2xl font-semibold mb-0">Contact Messages</h1>
            </div>
            <div class="flex items-center gap-6">
                <div class="text-center cursor-pointer">
                    <p class="text-gray-500">Un Read</p>
                    <span class="font-bold text-gray-800"><%= unreadMails %></span>
                </div>
                <div class="text-center cursor-pointer">
                    <p class="text-gray-500">Read</p>
                    <span class="font-bold text-gray-800"><%= readsMails %></span>
                </div>
                <div class="text-center cursor-pointer">
                    <p class="text-gray-500">Total</p>
                    <span class="font-bold text-gray-800"><%= totalMail %></span>
                </div>
            </div>
        </div>

        <!-- Messages Table -->
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="w-full">
                <thead class="bg-gray-200">
                    <tr>
                        <th class="px-4 py-2 text-left">Name</th>
                        <th class="px-4 py-2 text-left">Email</th>
                        <th class="px-4 py-2 text-left">Subject</th>
                        <th class="px-4 py-2 text-left">Date</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (adminMessages && adminMessages.length > 0) { %>
                        <% adminMessages.forEach(message => { %>
                            <tr class="border-b">
                                <td colspan="4" class="p-0">
<a href="/Api/admin-messages/message/<%= message._id %>"
   class="block w-full px-4 py-3 hover:bg-blue-50 cursor-pointer <%= message.status === 'unread' ? 'font-semibold' : '' %>"
  onclick="event.preventDefault(); 
         markAsRead('<%= message._id %>');
         showPopup(
             '<%= message.name %>',
             '<%= message.email %>',
             '<%= message.subject %>',
             `<%- message.message.replace(/`/g, '\\`') %>`,
             '<%= message.createdAt.toLocaleString('en-PK', { day:'2-digit', month:'short', year:'numeric' }) %>',
             this
         )";
>
  <div class="grid grid-cols-4 gap-4">
      <div><%= message.name %></div>
      <div><%= message.email %></div>
      <div><%= message.subject %></div>
      <div><%= message.createdAt.toLocaleString("en-PK", { day:'2-digit', month:'short', year:'numeric' }) %></div>
  </div>
</a>

                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="text-center py-6 text-gray-500">
                                No data available
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

    </main>

    <!-- Popup Container -->
    <div id="messagePopup"></div>

   <script>
    let lastClickedRow = null;



    function showPopup(name, email, subject, messageText, date, rowElement) {
        lastClickedRow = rowElement;

        const container = document.getElementById("messagePopup");
        container.innerHTML = `
            <div class="fixed inset-0 bg-black/50 flex justify-center items-center z-50">
                <div class="bg-white rounded-lg shadow-lg w-11/12 max-w-4xl h-4/5 flex flex-col overflow-hidden">
                    <div class="flex justify-between items-start p-4 border-b">
                        <div>
                            <h2 class="text-2xl font-bold mb-2">${subject}</h2>
                            <p class="text-gray-600"><b>From:</b> ${name}</p>
                            <p class="text-gray-600"><b>Email:</b> ${email}</p>
                            <p class="text-gray-500"><b>Date:</b> ${date}</p>
                        </div>
                        <button onclick="closePopup()" class="text-red-500 text-3xl font-bold">&times;</button>
                    </div>
                    <div class="p-6 overflow-y-auto flex-1 text-gray-700">
                        <p class="font-normal whitespace-pre-wrap">${messageText}</p>
                    </div>
                    <div class="flex justify-end p-4 border-t">
                        <button onclick="closePopup()" class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600">Close</button>
                    </div>
                </div>
            </div>
        `;

        rowElement.classList.remove("font-semibold");
    }

    function closePopup() {
        document.getElementById("messagePopup").innerHTML = "";
        lastClickedRow = null;
    }

       function markAsRead(id) {
    fetch(`/Api/admin-messages/message/${id}`, {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        }
    })
    .then(res => res.json())
    .then(data => console.log("Marked as read:", data))
    .catch(err => console.error("Fetch error:", err));
}
</script>

</body>
</html>
