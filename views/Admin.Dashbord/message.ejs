 <main class="md:ml-64 flex-1 p-6">

        <!-- Stats Bar -->
        <div class="flex items-center justify-between bg-white p-8 mb-5 rounded shadow-md">
            <div>
                <h1 class="text-2xl font-semibold mb-0">Contact Messages</h1>
            </div>
            <div class="flex items-center gap-6">
                <div class="text-center cursor-pointer">
                    <p class="text-gray-500">Un Read</p>
                    <span class="font-bold text-gray-800"><%= unreadMails %></span>
                </div>
                <div class="text-center cursor-pointer">
                    <p class="text-gray-500">Read</p>
                    <span class="font-bold text-gray-800"><%= readsMails %></span>
                </div>
                <div class="text-center cursor-pointer">
                    <p class="text-gray-500">Total</p>
                    <span class="font-bold text-gray-800"><%= totalMail %></span>
                </div>
            </div>
        </div>

        <!-- Messages Table -->
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="w-full">
                <thead class="bg-gray-200">
                    <tr>
                        <th class="px-4 py-2 text-left">Name</th>
                        <th class="px-4 py-2 text-left">Email</th>
                        <th class="px-4 py-2 text-left">Subject</th>
                        <th class="px-4 py-2 text-left">Date</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (adminMessages && adminMessages.length > 0) { %>
                        <% adminMessages.forEach(message => { %>
                            <tr class="border-b">
                                <td colspan="4" class="p-0">
<div class="message-row block w-full px-4 py-3 hover:bg-blue-50 cursor-pointer <%= message.status === 'unread' ? 'font-semibold' : '' %>"
     data-id="<%= message._id %>"
     data-name="<%= message.name %>"
     data-email="<%= message.email %>"
     data-subject="<%= message.subject %>"
     data-message-text="<%- message.message.replace(/`/g, '\\`') %>"
     data-date="<%= message.createdAt.toLocaleString('en-PK', { day:'2-digit', month:'short', year:'numeric' }) %>"
    >


  <div class="grid grid-cols-4 gap-4">
      <div><%= message.name %></div>
      <div><%= message.email %></div>
      <div><%= message.subject %></div>
      <div><%= message.createdAt.toLocaleString("en-PK", { day:'2-digit', month:'short', year:'numeric' }) %></div>
  </div>
</div>

                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="text-center py-6 text-gray-500">
                                No data available
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

    </main>

    <!-- Popup Container -->
    <div id="messagePopup"></div>