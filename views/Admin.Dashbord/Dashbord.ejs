<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

    <%-include("../../partial/AdminHeader.ejs")%>

        <!-- SIDEBAR -->
        <!-- Replace with your sidebar content if needed -->
        <!-- <div class="bg-white p-4 shadow mb-6">Admin Header / Sidebar Placeholder</div> -->

        <!-- MAIN WRAPPER -->
        <div class="sidebar-adjust max-w-7xl mx-auto p-4">

            <h1 class="text-2xl font-bold py-8 text-gray-800">Blog Analytics Dashboard</h1>

            <!-- STAT CARDS GRID -->
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">

                <!-- BLOGS -->
                <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                    <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">📝 Blogs</h3>
                    <div class="space-y-3">
                        <div class="flex justify-between border-b pb-2">
                            <p class="text-gray-600 text-sm">Total Blogs</p>
                            <span class="font-bold">120</span>
                        </div>
                        <div class="flex justify-between border-b pb-2">
                            <p class="text-gray-600 text-sm">This Month</p>
                            <span class="font-bold">15</span>
                        </div>
                        <div class="flex justify-between">
                            <p class="text-gray-600 text-sm">Today</p>
                            <span class="font-bold">2</span>
                        </div>
                    </div>
                </div>

                <!-- VIEWS -->
                <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                    <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">👁️ Views</h3>
                    <div class="space-y-3">
                        <div class="flex justify-between border-b pb-2">
                            <p class="text-gray-600 text-sm">Total Views</p>
                            <span class="font-bold">4500</span>
                        </div>
                        <div class="flex justify-between border-b pb-2">
                            <p class="text-gray-600 text-sm">This Month</p>
                            <span class="font-bold">300</span>
                        </div>
                        <div class="flex justify-between">
                            <p class="text-gray-600 text-sm">Today</p>
                            <span class="font-bold">20</span>
                        </div>
                    </div>
                </div>

                <!-- LIKES -->
                <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                    <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">❤️ Likes</h3>
                    <div class="space-y-3">
                        <div class="flex justify-between border-b pb-2">
                            <p class="text-gray-600 text-sm">Total Likes</p>
                            <span class="font-bold">800</span>
                        </div>
                        <div class="flex justify-between border-b pb-2">
                            <p class="text-gray-600 text-sm">This Month</p>
                            <span class="font-bold">50</span>
                        </div>
                        <div class="flex justify-between">
                            <p class="text-gray-600 text-sm">Today</p>
                            <span class="font-bold">5</span>
                        </div>
                    </div>
                </div>

                <!-- SHARES -->
                <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                    <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">🔗 Shares</h3>
                    <div class="space-y-3">
                        <div class="flex justify-between border-b pb-2">
                            <p class="text-gray-600 text-sm">Total Shares</p>
                            <span class="font-bold">200</span>
                        </div>
                        <div class="flex justify-between border-b pb-2">
                            <p class="text-gray-600 text-sm">This Month</p>
                            <span class="font-bold">20</span>
                        </div>
                        <div class="flex justify-between">
                            <p class="text-gray-600 text-sm">Today</p>
                            <span class="font-bold">2</span>
                        </div>
                    </div>
                </div>

                <!-- COMMENTS -->
                <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                    <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">💬 Comments</h3>
                    <div class="space-y-3">
                        <div class="flex justify-between border-b pb-2">
                            <p class="text-gray-600 text-sm">Total Comments</p>
                            <span class="font-bold">150</span>
                        </div>
                        <div class="flex justify-between border-b pb-2">
                            <p class="text-gray-600 text-sm">This Month</p>
                            <span class="font-bold">10</span>
                        </div>
                        <div class="flex justify-between">
                            <p class="text-gray-600 text-sm">Today</p>
                            <span class="font-bold">1</span>
                        </div>
                    </div>
                </div>

            </div>

            <!-- MAIN CHART DESIGN -->
            <section class="w-full px-6 py-8 bg-gray-100">
                <div class="bg-white p-6 rounded-xl w-full max-w-[1050px] h-[550px]">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-2xl font-bold text-gray-800">Performance Trend</h2>
                        <select class="border border-gray-300 px-3 py-2 rounded">
                            <option>Last 7 Days</option>
                            <option>Last 15 Days</option>
                            <option>Last 1 Month</option>
                            <option>Last 3 Months</option>
                            <option>Last 6 Months</option>
                            <option>Last 1 year</option>
                        </select>
                    </div>
                    <div
                        class="bg-white h-[450px] p-6 rounded-lg shadow-md flex items-center justify-center text-gray-400">
                        <span class="text-xl">Chart Placeholder</span>
                    </div>
                </div>
            </section>

            <!-- CATEGORIES -->
            <div class="bg-white rounded-lg shadow p-6 w-full mb-6">
                <h2 class="text-xl font-semibold text-gray-700 mb-4">Your Blog Categories</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                    <div class="border p-4 rounded-md flex items-center justify-between hover:bg-gray-50 transition">
                        <p class="text-gray-700 font-medium">Technology</p>
                        <span class="bg-blue-100 text-blue-600 px-3 py-1 rounded-full text-sm font-bold">12</span>
                    </div>
                    <div class="border p-4 rounded-md flex items-center justify-between hover:bg-gray-50 transition">
                        <p class="text-gray-700 font-medium">Health</p>
                        <span class="bg-blue-100 text-blue-600 px-3 py-1 rounded-full text-sm font-bold">8</span>
                    </div>
                    <div class="border p-4 rounded-md flex items-center justify-between hover:bg-gray-50 transition">
                        <p class="text-gray-700 font-medium">Education</p>
                        <span class="bg-blue-100 text-blue-600 px-3 py-1 rounded-full text-sm font-bold">5</span>
                    </div>
                </div>
            </div>

        </div>

</body>

</html>