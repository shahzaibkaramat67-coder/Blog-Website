<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100  w-full">

    <!-- ADMIN HEADER -->
    <%- include("../../partial/AdminHeader.ejs") %>

         <div class="md:ml-64 flex-1 p-6">
        <h1 class="text-3xl font-bold py-4 text-gray-800">Admin Dashboard</h1>

        <!-- Top Stat Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
            <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">📝 Blogs</h3>
                <div class="space-y-3">
                    <div class="flex justify-between border-b pb-2"><p>Total Blogs</p><span class="font-bold">120</span></div>
                    <div class="flex justify-between border-b pb-2"><p>This Month</p><span class="font-bold">15</span></div>
                    <div class="flex justify-between"><p>Today</p><span class="font-bold">2</span></div>
                </div>
            </div>
            <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">👁️ Views</h3>
                <div class="space-y-3">
                    <div class="flex justify-between border-b pb-2"><p>Total Views</p><span class="font-bold">4500</span></div>
                    <div class="flex justify-between border-b pb-2"><p>This Month</p><span class="font-bold">300</span></div>
                    <div class="flex justify-between"><p>Today</p><span class="font-bold">20</span></div>
                </div>
            </div>
            <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">❤️ Likes</h3>
                <div class="space-y-3">
                    <div class="flex justify-between border-b pb-2"><p>Total Likes</p><span class="font-bold">800</span></div>
                    <div class="flex justify-between border-b pb-2"><p>This Month</p><span class="font-bold">50</span></div>
                    <div class="flex justify-between"><p>Today</p><span class="font-bold">5</span></div>
                </div>
            </div>
            <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">🔗 Shares</h3>
                <div class="space-y-3">
                    <div class="flex justify-between border-b pb-2"><p>Total Shares</p><span class="font-bold">200</span></div>
                    <div class="flex justify-between border-b pb-2"><p>This Month</p><span class="font-bold">20</span></div>
                    <div class="flex justify-between"><p>Today</p><span class="font-bold">2</span></div>
                </div>
            </div>
        </div>

        <!-- Users Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 mb-8">
            <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">👤 Users</h3>
                <div class="space-y-3">
                    <div class="flex justify-between border-b pb-2"><p>Total Users</p><span class="font-bold">1,200</span></div>
                    <div class="flex justify-between border-b pb-2"><p>Active Users</p><span class="font-bold">950</span></div>
                    <div class="flex justify-between border-b pb-2"><p>New Today</p><span class="font-bold">12</span></div>
                    <div class="flex justify-between"><p>Banned Users</p><span class="font-bold">15</span></div>
                </div>
            </div>
            <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                <h3 class="text-lg font-semibold mb-3">Roles</h3>
                <div class="space-y-3">
                    <div class="flex justify-between border-b pb-2"><p>Admins</p><span class="font-bold">5</span></div>
                    <div class="flex justify-between border-b pb-2"><p>Vendors</p><span class="font-bold">120</span></div>
                    <div class="flex justify-between border-b pb-2"><p>Users</p><span class="font-bold">1,075</span></div>
                </div>
            </div>
            <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
                <h3 class="text-lg font-semibold mb-3">Activity</h3>
                <div class="space-y-3">
                    <div class="flex justify-between border-b pb-2"><p>Logged in Today</p><span class="font-bold">230</span></div>
                    <div class="flex justify-between border-b pb-2"><p>New Signups</p><span class="font-bold">12</span></div>
                    <div class="flex justify-between"><p>Inactive >30 days</p><span class="font-bold">45</span></div>
                </div>
            </div>
        </div>

        <!-- Charts -->
        <section class="mb-3">
            <div class="bg-white p-6 rounded-xl shadow">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-bold">Performance Trend</h2>
                    <select class="border border-gray-300 px-3 py-2 rounded">
                        <option>Last 7 Days</option>
                        <option>Last 15 Days</option>
                        <option>Last 1 Month</option>
                        <option>Last 3 Months</option>
                    </select>
                </div>
                <div class="bg-gray-50 h-64 flex items-center justify-center rounded">
                    Chart Placeholder
                </div>
            </div>
        </section>
        <section>
            <div class="bg-white p-6 rounded-xl shadow">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-bold">Earning Trend</h2>
                    <select class="border border-gray-300 px-3 py-2 rounded">
                        <option>Last 7 Days</option>
                        <option>Last 15 Days</option>
                        <option>Last 1 Month</option>
                        <option>Last 3 Months</option>
                    </select>
                </div>
                <div class="bg-gray-50 h-64 flex items-center justify-center rounded">
                    Chart Placeholder
                </div>
            </div>
        </section>

    </div>
</body>

</html>