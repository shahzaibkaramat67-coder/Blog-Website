<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Upload PDF with Blog Post</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center m-auto mr-1 max-w-5xl">


  <%-include('../partial/sidebar.ejs')%>

  <div class="w-full max-w-lg bg-white p-6 mt-8 shadow shadow-lg">
    <h1 class="text-2xl font-bold mb-6 text-gray-800">Upload Blog Post with PDF</h1>

    <form action="/api/user/uploads" method="POST" enctype="multipart/form-data" class="space-y-6">

      <!-- Blog Title -->
      <div>
        <label class="block text-gray-700 font-semibold mb-1">Post Title</label>
        <input type="text" name="title" required class="w-full p-3 border border-gray-300 rounded-lg focus:ring focus:ring-blue-200" placeholder="Enter blog title">
      </div>

      <!-- PDF Upload -->
      <div>
        <label class="block text-gray-700 font-semibold mb-1">Upload PDF File</label>
        <input type="file" name="pdf_file" accept=".pdf" required class="w-full p-2 border border-gray-300 rounded-lg bg-white">
        <p class="text-sm text-gray-500 mt-1">Only PDF files are allowed.</p>
      </div>

      <!-- Submit Button -->
      <div>
        <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
          Submit Blog Post with PDF
        </button>
      </div>

    </form>
  </div>

</body>
</html>
