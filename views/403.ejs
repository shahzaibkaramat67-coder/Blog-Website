<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title%></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-white flex items-center justify-center min-h-screen">
  <div class="text-center p-6">
    <h1 class="text-8xl font-bold text-red-600">403</h1>
    <h2 class="text-3xl md:text-4xl font-semibold mt-4">Access Denied</h2>
    <p class="mt-4 text-gray-400">You do not have permission to view this page.</p>

    <div class="mt-6 inline-block px-4 py-2 bg-gray-800 border-l-4 border-red-600 font-mono">
      Error Code: 403 Forbidden
    </div>

    <div class="mt-6">
      <a href="/" class="inline-block px-6 py-3 bg-red-600 hover:bg-red-700 rounded-lg font-semibold transition">
        Go Back Home
      </a>
    </div>
  </div>
</body>
</html>
