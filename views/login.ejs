<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/tailwind-build.css">
</head>
<body class="bg-slate-50">
  <%- include("../partial/Flash_response.ejs") %>
  <section class="min-h-screen flex items-center justify-center px-6 py-12">
    <div class="w-full max-w-5xl grid gap-8 lg:grid-cols-2">
      <div class="hidden lg:flex flex-col justify-between rounded-3xl bg-linear-to-br from-slate-900 via-slate-800 to-teal-700 p-10 text-white shadow-2xl">
        <div>
          <p class="text-sm uppercase tracking-widest text-white/70">BlogHub</p>
          <h1 class="mt-3 text-4xl font-semibold leading-tight">
            Welcome back. <br class="hidden xl:block">Pick up where you left off.
          </h1>
          <p class="mt-4 text-white/75">
            Publish stories, grow your audience, and track your impact with a clean, creator first dashboard.
          </p>
        </div>
        <div class="grid gap-3 text-sm text-white/80">
          <div class="flex items-center gap-2">
            <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10">✓</span>
            Insights on views, likes, and shares
          </div>
          <div class="flex items-center gap-2">
            <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10">✓</span>
            Fast publishing with beautiful templates
          </div>
          <div class="flex items-center gap-2">
            <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/10">✓</span>
            Safe, secure, and built for creators
          </div>
        </div>
      </div>

      <div class="rounded-3xl bg-white shadow-xl ring-1 ring-black/5 p-8 sm:p-10">
        <div class="mb-6">
          <p class="text-xs uppercase tracking-widest text-slate-400">Sign In</p>
          <h1 class="mt-2 text-2xl font-semibold text-slate-900"><%= isAdmin ? "Admin Panel Login" : "User Login" %></h1>
          <p class="mt-2 text-sm text-slate-500">Welcome back let’s get you into your dashboard.</p>
        </div>
        <form action="<%= isAdmin ? '/api/submit-login' : '/submit-login' %>" method="POST" class="space-y-5">
          <div>
            <label for="identifier" class="block text-sm font-medium text-slate-700">Username or Email</label>
            <input type="text" id="identifier" name="identifier" required class="mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200">
          </div>
          <div class="relative">
            <label for="password" class="block text-sm font-medium text-slate-700">Password</label>
            <input type="password" id="password" name="password" required class="mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200">
            <span class="absolute right-3 w-5 top-10">
              <img src="/assets/icons/eye-slash-solid-full.svg" class="toggle-password cursor-pointer" alt="">
            </span>
          </div>
          <div>
            <button type="submit" class="w-full rounded-xl bg-teal-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-700">Sign in</button>
          </div>

          <% if (!isAdmin) { %>
          <div class="text-sm text-center text-slate-500">
            <p>Don't have an account? <a href="/signup" class="font-medium text-teal-700 hover:text-teal-800">Sign Up</a></p>
            <p class="mt-1">Forgot password? <a href="/forgetPassword" class="font-medium text-teal-700 hover:text-teal-800">Reset</a></p>
          </div>
          <% } %>
        </form>
      </div>
    </div>
  </section>



<script src="/user/Login.js" defer></script>

</body>
</html>



