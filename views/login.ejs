<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title%>
  </title>
  <link rel="stylesheet" href="/all.css">
</head>

<body>
  <section>
    <div class="section-page">
      <div class="Singup">
        <h1>Login Here</h1>
      </div>
      <div class="form_Hendler">
        <form action="/submit-login" method="POST">
          <div class="form_date">
            <label for="identifier">Username or Email</label>
            <input type="text" id="identifier" name="identifier" required>
          </div>

          <div class="form_date">
            <label for="password">Password</label>
            <input type="password" id="password" name="password">
          </div>

          <div class="form_date">
            <button type="submit-login">submit</button>
          </div>
          <div>
            <p>if you have not account then Singup : <a href="./singup">Singup</a> </p>
          </div>

          <p><strong>if password not remember:</strong> <a href="/forgetPassword">forget password</a></p>
        </form>

      </div>
    </div>
  </section>
</body>

</html>
