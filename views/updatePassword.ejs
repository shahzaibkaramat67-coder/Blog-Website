<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title%></title>
  <link rel="stylesheet" href="/tailwind-build.css">
</head>

<body>
  <%- include("../partial/Flash_response.ejs") %>
  <section class="min-h-screen bg-slate-50 flex items-center justify-center px-6 py-12">
    <div class="w-full max-w-lg">
      <div class="bg-white rounded-3xl shadow-xl ring-1 ring-black/5 p-8 sm:p-10">
        <p class="text-xs uppercase tracking-widest text-slate-400">Security</p>
        <h1 class="mt-2 text-2xl font-semibold text-slate-900">Update Your Password</h1>
        <p class="mt-2 text-sm text-slate-500">Enter a new secure password. We’ll update your account after confirmation.</p>
        <form action="/submit-updatePassword" method="POST" class="space-y-5" novalidate>
          <input type="hidden" name="token" value="<%=token%>">

          <div>
            <label for="Password" class="block text-sm font-medium text-slate-700">New Password</label>
            <div class="relative mt-2">
              <input type="password" id="Password" class="password block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200" name="newPassword" placeholder="At least 8 characters">
              <span class="absolute right-3 top-3.5">
                <img src="/assets/icons/eye-slash-solid-full.svg" alt="toggle" class="toggle-password cursor-pointer" toggle="Password">
              </span>
            </div>
            <p class="text-xs text-slate-500 mt-2">Use a mix of letters, numbers &amp; symbols for stronger security.</p>
          </div>

          <div>
            <label for="confirmPassword" class="block text-sm font-medium text-slate-700">Confirm Password</label>
            <div class="relative mt-2">
              <input type="password" id="confirmPassword" class="password block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm outline-none transition focus:border-teal-500 focus:ring-2 focus:ring-teal-200" name="confirmPassword" placeholder="Repeat new password">
              <span class="absolute right-3 top-3.5">
                <img src="/assets/icons/eye-slash-solid-full.svg" alt="toggle" class="toggle-password cursor-pointer" toggle="confirmPassword">
              </span>
            </div>
            <p id="confirmError" class="text-sm text-red-500 mt-2 hidden">Passwords do not match.</p>
          </div>

          <div>
            <button type="submit" class="w-full rounded-xl bg-teal-600 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-700">Update Password</button>
          </div>
        </form>
      </div>
    </div>
  </section>


   <script src="/user/updatePassword.js" defer></script>


</body>

</html>
