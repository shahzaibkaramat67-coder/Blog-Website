<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title%>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <div class="max-w-4xl mx-auto bg-white shadow-md rounded-lg mt-10 p-8">
        <h1 class="capitalize text-black text-5xl p-3 text-center mb-3 font-bold">Create your profile</h1>
        <form action="/api/user/profile/edit-profile/profile-save" method="POST" enctype="multipart/form-data" class="space-y-6">
            <!-- Profile Header -->
            <div class="flex items-center space-x-6">
                <div class="h-24 w-24">
                    <img id="profilePreview" src="/assets/image/premium_photo-1664474619075-644dd191935f.jpeg" alt="Profile image preview" class="object-cover shadow w-full h-full cursor-pointer rounded-full">
                    <input id="profileImage" name="profile_Image" type="file" accept="image/*" class="hidden">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Full Name</label>
                    <input type="text" name="full_name"
                        class="mt-1 block w-full rounded-md border p-1.5 border-gray-300 shadow-sm focus:ring-blue-500" />
                    <label class="block mt-4 text-sm font-medium text-gray-700">@Username</label>
                    <input type="text" name="username"
                        class="mt-1 block w-full border p-1.5 rounded-md border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500" />
                </div>
            </div>

            <!-- About Me -->
            <div>
                <label class="block text-sm font-medium text-gray-700">About Me</label>
                <textarea name="about" rows="4"
                    class="mt-1 border p-1.5 block w-full rounded-md border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500"></textarea>
            </div>

            <!-- Contact Info -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <h2 class="text-lg font-semibold text-gray-700 mb-2">Contact Info</h2>
                    <label class="block text-sm font-medium text-gray-700">Email</label>
                    <input type="email" name="email"
                        class="mt-1 block w-full border p-1.5 rounded-md border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500" />
                    <label class="block mt-4 text-sm font-medium text-gray-700">Phone</label>
                    <input type="tel" name="phone"
                        class="mt-1 block w-full border p-1.5 rounded-md border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500" />
                    <label class="block mt-4 text-sm font-medium text-gray-700">Location</label>
                    <input type="text" name="location"
                        class="mt-1 block w-full border p-1.5 rounded-md border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500" />

                    <!-- New Field: Website -->
                    <label class="block mt-4 text-sm font-medium text-gray-700">Website</label>
                    <input type="url" name="website" placeholder="https://yourwebsite.com"
                        class="mt-1 block w-full rounded-md border p-1.5 border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500" />
                </div>

                <!-- Social Profiles -->
                <div>
                    <h2 class="text-lg font-semibold text-gray-700 mb-2">Social Profiles</h2>
                    <label class="block text-sm font-medium text-gray-700">Twitter</label>
                    <input type="url" name="twitter" placeholder="https://twitter.com/username"
                        class="mt-1 block w-full rounded-md border p-1.5 border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500" />
                    <label class="block mt-4 text-sm font-medium text-gray-700">LinkedIn</label>
                    <input type="url" name="linkedin" placeholder="https://linkedin.com/in/username"
                        class="mt-1 block w-full rounded-md border p-1.5 border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500" />
                    <label class="block mt-4 text-sm font-medium text-gray-700">Facebook</label>
                    <input type="url" name="facebook" placeholder="https://facebook.com/username"
                        class="mt-1 block w-full rounded-md border p-1.5 border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500" />
                </div>
            </div>

            <!-- Categories (Read-only or interactive tags) -->
            <div>
              
                    <label for="category" class="block text-sm font-medium text-gray-700 mb-1">Category</label>
                    <select name="category" id="category">
                
                    </select>
               
            </div>

            <!-- Submit -->
            <div class="pt-6">
                <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition">
                    Save Profile
                </button>
            </div>
        </form>
    </div>




    <script>

       

   

        //       fetch('http://localhost:3002/api/categorys/seed', methods ='get')
        //   .then(res => res.json())
        //   .then(data => console.log(data))
        //   .catch(err => console.error(err));
         const fileFromInput = document.querySelector("#profileImage")
        const imageToPlace = document.querySelector("#profilePreview")

        imageToPlace.addEventListener('click', ()=>{     
             fileFromInput.click()
        })


        fileFromInput.addEventListener('change', (e)=>{
          const files =  e.target.files[0]
          if (files) {
            const reader = new FileReader()
            reader.onload = ()=>{
                imageToPlace.src = reader.result;
            } 
            
            reader.readAsDataURL(files)
          }
            
        })


         

    </script>


</body>

</html>