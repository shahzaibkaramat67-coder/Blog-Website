<!DOCTYPE html>
<html lang="en" >
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Blogs & Apps Stats Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-gray-100 max-w-5xl p-6 m-auto mr-1 max-w-5xl">

    <%-include('../../partial/sidebar.ejs')%>
  <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-lg p-8">

    <h1 class="text-2xl font-bold mb-8 text-center">Blogs Stats Dashboard</h1>

    <div class="grid grid-cols-1 gap-8">

      <!-- Blog Stats Chart -->
      <section>
        <h2 class="text-2xl font-semibold mb-4 text-center">Blog Views Over Last 7 Days</h2>
        <canvas id="blogChart" class="max-w-full"></canvas>
      </section>

    </div>
  </div>

  <script>
    const blogCtx = document.getElementById('blogChart').getContext('2d');
   

    const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];

    // Sample Blog Views Data
    const blogData = [120, 150, 170, 140, 180, 200, 210];

   

    // Blog Views Chart
    const blogChart = new Chart(blogCtx, {
      type: 'line',
      data: {
        labels: days,
        datasets: [{
          label: 'Blog Views',
          data: blogData,
          borderColor: '#2563eb',
          backgroundColor: 'rgba(37, 99, 235, 0.2)',
          fill: true,
          tension: 0.3,
          pointRadius: 5,
          pointHoverRadius: 7,
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: true, position: 'top' }
        },
        scales: {
          y: { beginAtZero: true }
        }
      }
    });

  </script>
  
</body>
</html>
