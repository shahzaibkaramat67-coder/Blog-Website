<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Earnings Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6 m-auto mr-1 max-w-5xl">

  
    <%-include('../../partial/sidebar.ejs')%>

  <div class="max-w-5xl mx-auto bg-white rounded-lg shadow-lg p-8">
    <h1 class="text-3xl font-bold mb-6">Earnings Dashboard</h1>

    <!-- Summary cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="p-6 bg-blue-600 text-white rounded-lg shadow">
        <h2 class="text-xl font-semibold">Total Earnings</h2>
        <p class="mt-2 text-3xl">$<%= total %></p>
      </div>
      <div class="p-6 bg-green-600 text-white rounded-lg shadow">
        <h2 class="text-xl font-semibold">Monthly Earnings</h2>
        <p class="mt-2 text-3xl">$<%= month %></p>
      </div>
      <div class="p-6 bg-yellow-500 text-white rounded-lg shadow">
        <h2 class="text-xl font-semibold">today Earnings</h2>
        <p class="mt-2 text-3xl">$<%= today %></p>
      </div>
      <div class="p-6 bg-red-500 text-white rounded-lg shadow">
        <h2 class="text-xl font-semibold">Available Balance</h2>
        <p class="mt-2 text-3xl"><%= available%></p>
        <span>Pending</span>
      </div>
    </div>

    <!-- Recent Transactions -->
    <section>
      <h2 class="text-2xl font-semibold mb-4">Recent Transactions</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-gray-200">
              <th class="p-3">Username</th>
              <th class="p-3">Date</th>
              <th class="p-3">Amount</th>
              <th class="p-3">Status</th>
            </tr>
          </thead>
          <tbody>
            
            <% if (withdrawalRequest && withdrawalRequest.length > 0) {%>
              <% withdrawalRequest.forEach(w => {%>
                
                <tr class="border-t">
                 <td class="p-3"><%= w.user.Username%></td>
              <td class="p-3"><%= w.createdAt.toDateString()%></td>
              <td class="p-3 text-green-600 font-semibold"><%= w.amount%></td>
              <td class="p-3 font-semibold <%= w.status === 'pending' ? 'text-red-500' : 'text-green-700' %> "><%= w.status%></td>
              
              </tr>

              <%}) %>

            <%  }else{ %>
              <p class="p-3 text-green-700 font-semibold">No Request Yet</p>
          <%  }  %>
          </tbody>
        </table>
      </div>
    </section>
  </div>

</body>
</html>
