<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="bg-gray-100">

  <%- include('../../partial/sidebar.ejs') %>

    <div class="max-w-7xl ml-[280px] p-6">


      <div class="m-auto p-6">
        <h1 class="text-2xl font-bold mb-6 text-gray-800">Blog Analytics Dashboard</h1>

        <!-- STAT CARDS -->
        <!-- STAT CARDS -->
        <!-- BLOG / LIKES / SHARES / COMMENTS METRICS -->
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-8">

          <!-- ✅ BLOGS METRICS -->
          <div class="bg-white p-5 rounded-lg shadow">
            <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">
              📝 Blogs
            </h3>

            <div class="space-y-3">
              <div class="flex justify-between border-b pb-2">
                <p class="text-gray-600 text-sm">Total Blogs</p>
                <span class="font-bold text-gray-800">127</span>
              </div>
              <div class="flex justify-between border-b pb-2">
                <p class="text-gray-600 text-sm">This Month</p>
                <span class="font-bold text-gray-800">22</span>
              </div>
              <div class="flex justify-between">
                <p class="text-gray-600 text-sm">Today</p>
                <span class="font-bold text-gray-800">3</span>
              </div>
            </div>
          </div>

          <!-- ✅ LIKES METRICS -->
          <div class="bg-white p-5 rounded-lg shadow">
            <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">
              ❤️ Likes
            </h3>

            <div class="space-y-3">
              <div class="flex justify-between border-b pb-2">
                <p class="text-gray-600 text-sm">Total Likes</p>
                <span class="font-bold text-gray-800">12,340</span>
              </div>
              <div class="flex justify-between border-b pb-2">
                <p class="text-gray-600 text-sm">This Month</p>
                <span class="font-bold text-gray-800">1,120</span>
              </div>
              <div class="flex justify-between">
                <p class="text-gray-600 text-sm">Today</p>
                <span class="font-bold text-gray-800">44</span>
              </div>
            </div>
          </div>

          <!-- ✅ SHARES METRICS -->
          <div class="bg-white p-5 rounded-lg shadow">
            <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">
              🔗 Shares
            </h3>

            <div class="space-y-3">
              <div class="flex justify-between border-b pb-2">
                <p class="text-gray-600 text-sm">Total Shares</p>
                <span class="font-bold text-gray-800">6,780</span>
              </div>
              <div class="flex justify-between border-b pb-2">
                <p class="text-gray-600 text-sm">This Month</p>
                <span class="font-bold text-gray-800">820</span>
              </div>
              <div class="flex justify-between">
                <p class="text-gray-600 text-sm">Today</p>
                <span class="font-bold text-gray-800">18</span>
              </div>
            </div>
          </div>

          <!-- ✅ COMMENTS METRICS -->
          <div class="bg-white p-5 rounded-lg shadow">
            <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">
              💬 Comments
            </h3>

            <div class="space-y-3">
              <div class="flex justify-between border-b pb-2">
                <p class="text-gray-600 text-sm">Total Comments</p>
                <span class="font-bold text-gray-800">3,520</span>
              </div>
              <div class="flex justify-between border-b pb-2">
                <p class="text-gray-600 text-sm">This Month</p>
                <span class="font-bold text-gray-800">290</span>
              </div>
              <div class="flex justify-between">
                <p class="text-gray-600 text-sm">Today</p>
                <span class="font-bold text-gray-800">9</span>
              </div>
            </div>
          </div>

        </div>



        <!-- MAIN CHART (FULL-WIDTH) -->
        <div class="bg-white rounded-lg shadow p-6 w-full mb-10">
          <h2 class="text-xl font-semibold text-gray-700 text-center mb-3">
            Blog Views - Last 30 Days
          </h2>

          <div class="w-full">
            <canvas id="blogChart" class="h-48"></canvas>
            <!-- h-48 gives smaller height -->
          </div>
        </div>


        <!-- BLOG CATEGORIES SECTION -->
        <div class="bg-white rounded-lg shadow p-6 w-full">
          <h2 class="text-xl font-semibold text-gray-700 mb-4">
            Your Blog Categories
          </h2>

          <!-- Category List -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

            <!-- Category card -->
            <div class="border p-4 rounded-md flex items-center justify-between">
              <p class="text-gray-700 font-medium">Technology</p>
              <span class="bg-blue-100 text-blue-600 px-3 py-1 rounded-full text-sm font-bold">
                14
              </span>
            </div>

            <div class="border p-4 rounded-md flex items-center justify-between">
              <p class="text-gray-700 font-medium">Lifestyle</p>
              <span class="bg-green-100 text-green-600 px-3 py-1 rounded-full text-sm font-bold">
                9
              </span>
            </div>

            <div class="border p-4 rounded-md flex items-center justify-between">
              <p class="text-gray-700 font-medium">Sports</p>
              <span class="bg-purple-100 text-purple-600 px-3 py-1 rounded-full text-sm font-bold">
                6
              </span>
            </div>

            <!-- Add more using loop -->
          </div>
        </div>
      </div>

    </div>

    <script>
      const ctx = document.getElementById('blogChart').getContext('2d');

      const days = Array.from({ length: 30 }, (_, i) => `Day ${i + 1}`);
      const blogData = [55, 75, 60, 80, 120, 200, 160, 90, 110, 130, 90, 70, 95, 100, 140, 180,
        175, 220, 260, 240, 200, 180, 160, 150, 140, 130, 120, 100, 90, 70];

      new Chart(ctx, {
        type: 'line',
        data: {
          labels: days,
          datasets: [{
            label: "Views",
            data: blogData,
            borderColor: "#2563eb",
            backgroundColor: "rgba(37, 99, 235, 0.25)",
            fill: true,
            tension: 0.35,
            pointRadius: 0
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,   // allows full div width + fixed height
          scales: {
            y: { beginAtZero: true }
          }
        }
      });
    </script>

</body>

</html>