<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="bg-gray-100">

  <!-- SIDEBAR -->
  <%- include('../../partial/sidebar.ejs') %>

    <!-- MAIN WRAPPER -->
    <div class="sidebar-adjust max-w-7xl mx-auto p-4 lg:ml-[260px]">

      <h1 class="text-2xl font-bold mb-6 text-gray-800">Blog Analytics Dashboard</h1>

      <!-- ✅ STAT CARDS GRID -->
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">

        <!-- ✅ BLOGS -->
        <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
          <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">📝 Blogs</h3>
          <div class="space-y-3">
            <div class="flex justify-between border-b pb-2">
              <p class="text-gray-600 text-sm">Total Blogs</p>
              <span class="font-bold">
                <%= allPostedArtical %>
              </span>
            </div>
            <div class="flex justify-between border-b pb-2">
              <p class="text-gray-600 text-sm">This Month</p>
              <span class="font-bold">
                <%= monthlyCreatedArtical %>
              </span>
            </div>
            <div class="flex justify-between">
              <p class="text-gray-600 text-sm">Today</p>
              <span class="font-bold">
                <%= todayArtical %>
              </span>
            </div>
          </div>
        </div>

        <!-- ✅ VIEWS -->
        <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
          <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">👁️ Views</h3>
          <div class="space-y-3">
            <div class="flex justify-between border-b pb-2">
              <p class="text-gray-600 text-sm">Total Views</p>
              <span class="font-bold">
                <%= totalViews %>
              </span>
            </div>
            <div class="flex justify-between border-b pb-2">
              <p class="text-gray-600 text-sm">This Month</p>
              <span class="font-bold">
                <%= monthViews %>
              </span>
            </div>
            <div class="flex justify-between">
              <p class="text-gray-600 text-sm">Today</p>
              <span class="font-bold">
                <%= todayViews %>
              </span>
            </div>
          </div>
        </div>

        <!-- ✅ LIKES -->
        <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
          <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">❤️ Likes</h3>
          <div class="space-y-3">
            <div class="flex justify-between border-b pb-2">
              <p class="text-gray-600 text-sm">Total Likes</p>
              <span class="font-bold">
                <%= likes %>
              </span>
            </div>
            <div class="flex justify-between border-b pb-2">
              <p class="text-gray-600 text-sm">This Month</p>
              <span class="font-bold">
                <%= monthlyLikes %>
              </span>
            </div>
            <div class="flex justify-between">
              <p class="text-gray-600 text-sm">Today</p>
              <span class="font-bold">
                <%= dayLikes %>
              </span>
            </div>
          </div>
        </div>

        <!-- ✅ SHARES -->
        <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
          <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">🔗 Shares</h3>
          <div class="space-y-3">
            <div class="flex justify-between border-b pb-2">
              <p class="text-gray-600 text-sm">Total Shares</p>
              <span class="font-bold">
                <%= totalShareArticals %>
              </span>
            </div>
            <div class="flex justify-between border-b pb-2">
              <p class="text-gray-600 text-sm">This Month</p>
              <span class="font-bold">
                <%= monthlyShares %>
              </span>
            </div>
            <div class="flex justify-between">
              <p class="text-gray-600 text-sm">Today</p>
              <span class="font-bold">
                <%= dayShares %>
              </span>
            </div>
          </div>
        </div>

        <!-- ✅ COMMENTS -->
        <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
          <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">💬 Comments</h3>
          <div class="space-y-3">
            <div class="flex justify-between border-b pb-2">
              <p class="text-gray-600 text-sm">Total Comments</p>
              <span class="font-bold">
                <%= comments %>
              </span>
            </div>
            <div class="flex justify-between border-b pb-2">
              <p class="text-gray-600 text-sm">This Month</p>
              <span class="font-bold">
                <%= monthlyComment %>
              </span>
            </div>
            <div class="flex justify-between">
              <p class="text-gray-600 text-sm">Today</p>
              <span class="font-bold">
                <%= dayCommets %>
              </span>
            </div>
          </div>
        </div>

      </div>

      <!-- ✅ MAIN CHART -->

      <section class="w-full px-6 py-8 bg-gray-100">
        <div class="bg-white p-6 rounded-xl w-full max-w-[1050px] h-[550px]">
          <!-- Header + Range Selector -->
          <div class="flex justify-between items-center mb-6">
            <h2 class="text-2xl font-bold text-gray-800">Performance Trend</h2>
            <select id="rangeSelect" class="border border-gray-300 px-3 py-2 rounded">
              <option value="7">Last 7 Days</option>
              <option value="15">Last 15 Days</option>
              <option value="30">Last 1 Month</option>
              <option value="90">Last 3 Months</option>
            </select>
          </div>
          <!-- Chart Card -->
          <div class="bg-white h-[450px]  p-6 rounded-lg shadow-md">
            <canvas id="trendChart"></canvas>
          </div>
        </div>
      </section>
      <!-- ✅ CATEGORIES -->
      <div class="bg-white rounded-lg shadow p-6 w-full mb-6">
        <h2 class="text-xl font-semibold text-gray-700 mb-4">Your Blog Categories</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% if (categoryState && categoryState.length> 0) { %>
            <% categoryState.forEach(item=> { %>
              <div class="border p-4 rounded-md flex items-center justify-between hover:bg-gray-50 transition">
                <p class="text-gray-700 font-medium">
                  <%= item.name %>
                </p>
                <span class="bg-blue-100 text-blue-600 px-3 py-1 rounded-full text-sm font-bold">
                  <%= item.count %>
                </span>
              </div>
              <% }); %>
                <% } else { %>
                  <p class="text-gray-600">No Categories Found</p>
                  <% } %>
        </div>
      </div>

    </div>

<script>
const rangeSelect = document.getElementById("rangeSelect");
const ctx = document.getElementById("trendChart").getContext("2d");

// Initial empty chart
let chart = new Chart(ctx, {
  type: "line",
  data: {
    labels: [],          // empty initially
    datasets: [
      { label: "Views", data: [], borderColor: "red", fill: false },
      { label: "Likes", data: [], borderColor: "green", fill: false },
      { label: "Shares", data: [], borderColor: "blue", fill: false }
    ]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: true } },
    scales: {
      x: { ticks: { color: "#555" } },
      y: { beginAtZero: true, ticks: { color: "#555" } }
    }
  }
});

// Fetch initial data for default range (7 days)
async function loadChart(days = 7) {
  try {
    const res = await fetch(`/profile/Dashbord/my-Dashboard/data?days=${days}`);
    const apiData = await res.json();

    chart.data.labels = apiData.labels;
    chart.data.datasets[0].data = apiData.views;
    chart.data.datasets[1].data = apiData.likes;
    chart.data.datasets[2].data = apiData.shares;
    chart.update();
  } catch (err) {
    console.error("Failed to fetch chart data", err);
  }
}

// Load default chart on page load
loadChart();

// Update chart when range changes
rangeSelect.addEventListener("change", () => {
  const days = rangeSelect.value;
  loadChart(days);
});
</script>



  </body>
  </html>

    <!-- ✅ CHART SCRIPT -->