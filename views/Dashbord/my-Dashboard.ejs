        <div class="flex justify-between border-b pb-2">
          <p class="text-gray-600">This Month</p>
          <span class="font-bold"><%= monthlyCreatedArtical %></span>
        </div>
        <div class="flex justify-between">
          <p class="text-gray-600">Today</p>
          <span class="font-bold"><%= todayArtical %></span>
        </div>
      </div>
    </div>
    <div class="bg-white p-4 sm:p-5 rounded-xl shadow-sm hover:shadow-md transition duration-300">
      <h3 class="text-base sm:text-lg font-semibold text-gray-800 mb-3">📝 Blogs</h3>
      <div class="space-y-3 text-sm sm:text-base">
        <div class="flex justify-between border-b pb-2">
          <p class="text-gray-600">👁️ Views</p>
          <span class="font-bold"><%= totalViews %></span>
        </div>
        <div class="flex justify-between border-b pb-2">
          <p class="text-gray-600">This Month</p>
          <span class="font-bold"><%= monthViews %></span>
        </div>
        <div class="flex justify-between">
          <p class="text-gray-600">Today</p>
          <span class="font-bold"><%= todayViews %></span>
        </div>
      </div>
    </div>
    <div class="bg-white p-4 sm:p-5 rounded-xl shadow-sm hover:shadow-md transition duration-300">
      <h3 class="text-base sm:text-lg font-semibold text-gray-800 mb-3">📝 Blogs</h3>
      <div class="space-y-3 text-sm sm:text-base">
        <div class="flex justify-between border-b pb-2">
          <p class="text-gray-600">❤️ Likes</p>
          <span class="font-bold"><%= likes %></span>
        </div>
        <div class="flex justify-between border-b pb-2">
          <p class="text-gray-600">This Month</p>
          <span class="font-bold"><%= monthlyLikes %></span>
        </div>
        <div class="flex justify-between">
          <p class="text-gray-600">Today</p>
          <span class="font-bold"><%= dayLikes %></span>
        </div>
      </div>
    </div>
    <div class="bg-white p-4 sm:p-5 rounded-xl shadow-sm hover:shadow-md transition duration-300">
      <h3 class="text-base sm:text-lg font-semibold text-gray-800 mb-3">📝 Blogs</h3>
      <div class="space-y-3 text-sm sm:text-base">
        <div class="flex justify-between border-b pb-2">
          <p class="text-gray-600">🔗 Shares</p>
          <span class="font-bold"><%= totalShareArticals %></span>
        </div>
        <div class="flex justify-between border-b pb-2">
          <p class="text-gray-600">This Month</p>
          <span class="font-bold"><%= monthlyShares %></span>
        </div>
        <div class="flex justify-between">
          <p class="text-gray-600">Today</p>
          <span class="font-bold"><%= dayShares %></span>
        </div>
      </div>
    </div>
    <div class="bg-white p-4 sm:p-5 rounded-xl shadow-sm hover:shadow-md transition duration-300">
      <h3 class="text-base sm:text-lg font-semibold text-gray-800 mb-3">📝 Blogs</h3>
      <div class="space-y-3 text-sm sm:text-base">
        <div class="flex justify-between border-b pb-2">
          <p class="text-gray-600">💬 Comments</p>
          <span class="font-bold"><%= comments %></span>
        </div>
        <div class="flex justify-between border-b pb-2">
          <p class="text-gray-600">This Month</p>
          <span class="font-bold"><%= monthlyComment %></span>
        </div>
        <div class="flex justify-between">
          <p class="text-gray-600">Today</p>
          <span class="font-bold"><%= dayCommets %></span>
        </div>
      </div>
    </div>

    <!-- Duplicate this structure for other stat cards (Views, Likes, etc.) -->
    
  </div>

  <!-- ============================= -->
  <!-- ✅ PERFORMANCE CHART -->
  <!-- ============================= -->

  <section class="w-full mb-8">
    <div class="bg-white p-4 sm:p-6 rounded-xl shadow-sm w-full">

      <!-- Header -->
      <div class="flex flex-col sm:flex-row 
                  sm:items-center 
                  sm:justify-between 
                  gap-4 mb-6">

        <h2 class="text-lg sm:text-xl lg:text-2xl font-bold text-gray-800">
          Performance Trend
        </h2>

        <select id="rangeSelect"
          class="border border-gray-300 px-3 py-2 rounded-md text-sm sm:text-base w-full sm:w-auto">
          <option value="7">Last 7 Days</option>
          <option value="15">Last 15 Days</option>
          <option value="30">Last 1 Month</option>
          <option value="90">Last 3 Months</option>
        </select>
      </div>

      <!-- Responsive Chart Container -->
      <div class="relative w-full h-[300px] sm:h-[400px] lg:h-[450px]">
        <canvas id="trendChart" class="w-full h-full"></canvas>
      </div>

    </div>
  </section>

  <!-- ============================= -->
  <!-- ✅ CATEGORIES SECTION -->
  <!-- ============================= -->

  <div class="bg-white rounded-xl shadow-sm p-4 sm:p-6 w-full mb-8">
    <h2 class="text-lg sm:text-xl font-semibold text-gray-700 mb-4">
      Your Blog Categories
    </h2>

    <div class="grid 
                grid-cols-1 
                sm:grid-cols-2 
                lg:grid-cols-3 
                gap-4">

      <% if (categoryState && categoryState.length > 0) { %>
        <% categoryState.forEach(item => { %>
          <div class="border p-4 rounded-lg 
                      flex items-center justify-between 
                      hover:bg-gray-50 transition">
            <p class="text-gray-700 font-medium text-sm sm:text-base">
              <%= item.name %>
            </p>
            <span class="bg-blue-100 text-blue-600 
                         px-3 py-1 rounded-full 
                         text-xs sm:text-sm font-bold">
              <%= item.count %>
            </span>
          </div>
        <% }); %>
      <% } else { %>
        <p class="text-gray-600">No Categories Found</p>
      <% } %>

    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
const rangeSelect = document.getElementById("rangeSelect");
const ctx = document.getElementById("trendChart").getContext("2d");

// Initial empty chart
let chart = new Chart(ctx, {
  type: "line",
  data: {
    labels: [],          // empty initially
    datasets: [
      { label: "Views", data: [], borderColor: "red", fill: false },
      { label: "Likes", data: [], borderColor: "green", fill: false },
      { label: "Shares", data: [], borderColor: "blue", fill: false }
    ]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: true } },
    scales: {
      x: { ticks: { color: "#555" } },
      y: { beginAtZero: true, ticks: { color: "#555" } }
    }
  }
});

// Fetch initial data for default range (7 days)
async function loadChart(days = 7) {
  try {
    const res = await fetch(`/profile/Dashbord/my-Dashboard/data?days=${days}`);
    const apiData = await res.json();

    chart.data.labels = apiData.labels;
    chart.data.datasets[0].data = apiData.views;
    chart.data.datasets[1].data = apiData.likes;
    chart.data.datasets[2].data = apiData.shares;
    chart.update();
  } catch (err) {
    console.error("Failed to fetch chart data", err);
  }
}

// Load default chart on page load
loadChart();

// Update chart when range changes
rangeSelect.addEventListener("change", () => {
  const days = rangeSelect.value;
  loadChart(days);
});
</script>