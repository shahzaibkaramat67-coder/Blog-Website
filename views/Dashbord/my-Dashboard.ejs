<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    @media (max-width: 1024px) {
      .sidebar-adjust {
        margin-left: 0 !important;
      }
    }
  </style>
</head>

<body class="bg-gray-100">

  <!-- SIDEBAR -->
  <%- include('../../partial/sidebar.ejs') %>

  <!-- MAIN WRAPPER -->
  <div class="sidebar-adjust max-w-7xl mx-auto p-4 lg:ml-[260px]">

    <h1 class="text-2xl font-bold mb-6 text-gray-800">Blog Analytics Dashboard</h1>

    <!-- ✅ STAT CARDS GRID -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">

      <!-- ✅ BLOGS -->
      <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
        <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">📝 Blogs</h3>
        <div class="space-y-3">
          <div class="flex justify-between border-b pb-2">
            <p class="text-gray-600 text-sm">Total Blogs</p>
            <span class="font-bold"><%= allPostedArtical %></span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <p class="text-gray-600 text-sm">This Month</p>
            <span class="font-bold"><%= monthlyCreatedArtical %></span>
          </div>
          <div class="flex justify-between">
            <p class="text-gray-600 text-sm">Today</p>
            <span class="font-bold"><%= todayArtical %></span>
          </div>
        </div>
      </div>

      <!-- ✅ VIEWS -->
      <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
        <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">👁️ Views</h3>
        <div class="space-y-3">
          <div class="flex justify-between border-b pb-2">
            <p class="text-gray-600 text-sm">Total Views</p>
            <span class="font-bold"><%= totalViews %></span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <p class="text-gray-600 text-sm">This Month</p>
            <span class="font-bold"><%= monthlyViews %></span>
          </div>
          <div class="flex justify-between">
            <p class="text-gray-600 text-sm">Today</p>
            <span class="font-bold"><%= dailyViews %></span>
          </div>
        </div>
      </div>

      <!-- ✅ LIKES -->
      <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
        <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">❤️ Likes</h3>
        <div class="space-y-3">
          <div class="flex justify-between border-b pb-2">
            <p class="text-gray-600 text-sm">Total Likes</p>
            <span class="font-bold"><%= likes %></span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <p class="text-gray-600 text-sm">This Month</p>
            <span class="font-bold"><%= monthlyLikes %></span>
          </div>
          <div class="flex justify-between">
            <p class="text-gray-600 text-sm">Today</p>
            <span class="font-bold"><%= dayLikes %></span>
          </div>
        </div>
      </div>

      <!-- ✅ SHARES -->
      <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
        <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">🔗 Shares</h3>
        <div class="space-y-3">
          <div class="flex justify-between border-b pb-2">
            <p class="text-gray-600 text-sm">Total Shares</p>
            <span class="font-bold">6,780</span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <p class="text-gray-600 text-sm">This Month</p>
            <span class="font-bold">820</span>
          </div>
          <div class="flex justify-between">
            <p class="text-gray-600 text-sm">Today</p>
            <span class="font-bold">18</span>
          </div>
        </div>
      </div>

      <!-- ✅ COMMENTS -->
      <div class="bg-white p-5 rounded-lg shadow hover:shadow-md transition">
        <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">💬 Comments</h3>
        <div class="space-y-3">
          <div class="flex justify-between border-b pb-2">
            <p class="text-gray-600 text-sm">Total Comments</p>
            <span class="font-bold"><%= comments %></span>
          </div>
          <div class="flex justify-between border-b pb-2">
            <p class="text-gray-600 text-sm">This Month</p>
            <span class="font-bold"><%= monthlyComment %></span>
          </div>
          <div class="flex justify-between">
            <p class="text-gray-600 text-sm">Today</p>
            <span class="font-bold"><%= dayCommets %></span>
          </div>
        </div>
      </div>

    </div>

    <!-- ✅ MAIN CHART -->
    <div class="bg-white rounded-lg shadow p-6 w-full mb-10">
      <h2 class="text-xl font-semibold text-gray-700 text-center mb-4">Blog Views - Last 30 Days</h2>
      <div class="w-full h-56 md:h-72">
        <canvas id="blogChart"></canvas>
      </div>
    </div>

    <!-- ✅ CATEGORIES -->
    <div class="bg-white rounded-lg shadow p-6 w-full mb-6">
      <h2 class="text-xl font-semibold text-gray-700 mb-4">Your Blog Categories</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% if (categoryState && categoryState.length > 0) { %>
          <% categoryState.forEach(item => { %>
            <div class="border p-4 rounded-md flex items-center justify-between hover:bg-gray-50 transition">
              <p class="text-gray-700 font-medium"><%= item.name %></p>
              <span class="bg-blue-100 text-blue-600 px-3 py-1 rounded-full text-sm font-bold">
                <%= item.count %>
              </span>
            </div>
          <% }); %>
        <% } else { %>
          <p class="text-gray-600">No Categories Found</p>
        <% } %>
      </div>
    </div>

  </div>

  <!-- ✅ CHART SCRIPT -->
  <script>
    const ctx = document.getElementById('blogChart').getContext('2d');

    const days = Array.from({ length: 30 }, (_, i) => `Day ${i + 1}`);
    const blogData = [55, 75, 60, 80, 120, 200, 160, 90, 110, 130, 90, 70, 95, 100, 140, 180,
      175, 220, 260, 240, 200, 180, 160, 150, 140, 130, 120, 100, 90, 70];

    new Chart(ctx, {
      type: 'line',
      data: {
        labels: days,
        datasets: [{
          label: "Views",
          data: blogData,
          borderColor: "#2563eb",
          backgroundColor: "rgba(37, 99, 235, 0.25)",
          fill: true,
          tension: 0.35,
          pointRadius: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: { y: { beginAtZero: true } }
      }
    });
  </script>

</body>
</html>
