<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Withdraw Funds</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-800 min-h-screen flex flex-col items-center py-10">

  
    <%-include('../../partial/sidebar.ejs')%>

  <div class="bg-white shadow-md rounded-lg w-full max-w-2xl p-6">
    <h2 class="text-2xl font-bold mb-4">Withdraw Funds</h2>

    <form id="EarningRequest" class="space-y-6" action="/profile/Dashbord/Withdraw/submit" method="POST">
      <!-- Withdrawal Amount -->
      <div>
        <label class="block text-sm font-semibold mb-1">Amount (PKR)</label>
        <input type="number" name="amount" min="10" required
          class="w-full border rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Enter amount" />
      </div>

      <!-- Withdrawal Method -->
      <div>
        <label class="block text-sm font-semibold mb-1">Select Withdrawal Method</label>
        <select id="method" name="method" required
          class="w-full border rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">-- Select Method --</option>
          <option value="bank">Bank Transfer (IBAN)</option>
          <option value="easypaisa">Easypaisa</option>
          <option value="jazzcash">JazzCash</option>
          <option value="payoneer">Payoneer</option>
          <option value="sadapay">SadaPay</option>
        </select>
      </div>

      <!-- Account Info -->
      <div>
        <label class="block text-sm font-semibold mb-1">Account Details</label>
        <input type="text" id="accountDetails" name="accountDetails" required
          class="w-full border rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
          placeholder="" />
      </div>

      <!-- Submit Button -->
      <div>
        <button type="submit"
          class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2 rounded-md transition duration-200">
          Submit Withdrawal Request
        </button>
      </div>
    </form>

    <!-- Optional: Withdrawal Instructions -->
    <div class="mt-6 text-sm text-gray-600">
      <p><strong>Note:</strong></p>
      <ul class="list-disc list-inside">
        <li>Minimum withdrawal is 10$</li>
        <li>Requests are processed within 3-5 business days</li>
        <li>Make sure your account information is accurate</li>
      </ul>
    </div>
  </div>

 

<script>

const methodToWithdraw = document.getElementById("method"); 
const accountDetails = document.getElementById("accountDetails");
 
methodToWithdraw.addEventListener("change", function (){
  const method = this.value;

  // ["bank", "easypaisa", "jazzcash", "payoneer", "sadapay"],

  if (method === "easypaisa" || method === "jazzcash") {
    accountDetails.placeholder = "Enter Mobile Number (03XXXXXXXXX)";
    accountDetails.type = "tel"

  }
  else if (method === "payoneer" || method === "sadapay") {
    accountDetails.placeholder = "Enter registered email address";
    accountDetails.type = "text"

  }
  else  {
    accountDetails.placeholder = "Enter Account Details";
    accountDetails.type = "text"

  }
})





</script>



</body>
</html>
