<section class="max-w-4xl mx-auto mt-8">

  <% if (articalById) { %>
    <div class="bg-white shadow-lg rounded-lg p-6 mb-8">

      <!-- Title -->
      <h1 class="text-3xl flex justify-center font-bold mb-2">
        <%= articalById.title %>
      </h1>

      <!-- Author -->
      <a href="/profile" class="flex gap-2 items-center mb-4">
        <img  src="<%= articalById.featured_image %>" alt="profile_image" loading="lazy" alt="Description" class="rounded-lg h-10 w-10">
        <h2 class="text-2xl font-bold">
          <%= articalById.username?.username || "Unknown" %>
        </h2>
      </a>

      <!-- Publish Date -->
      <p class="text-gray-500 text-sm mb-4">
        By <span class="font-semibold"><%= articalById.username?.username || "Unknown" %></span> |
        <%= new Date(articalById.publish_date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }) %>
      </p>

      <!-- Featured Image -->
      <img src="<%= articalById.featured_image %>" alt="Article Image" class="rounded-lg mb-6 w-full h-60 object-cover">

      <!-- Blog Content -->
      <div class="prose max-w-none mb-6">
        <%= articalById.content %>
      </div>

      <!-- Like & Share -->
      <div class="flex items-center justify-between border-t border-b py-3">
        <button class="like-btn flex items-center gap-2 text-blue-600 hover:text-blue-800" data-id="<%= articalById._id %>">
          <span class="heart"><%= liked ? "❤️ Unlike" : "🤍 Like" %></span>
        </button>
  
        <div class="flex gap-3">
          <button id="openPopup"  data-id="<%= articalById._id%>" href="#" class="text-blue-500 hover:text-blue-700">🔗 Share</button>
        </div>
      </div>

      <!-- Comments -->
      <%- include("../partial/comments.ejs", { articalById: articalById._id, comments }) %>

    </div>
  <% } else { %>
    <p class="text-center text-gray-500 py-6">Article not found.</p>
  <% } %>

>


