<style>
  /* Pro-grade scroll entrance + subtle tilt on pointer move */
  .card {
    --ty: 36px;   /* translate Y until revealed */
    --rx: 8deg;   /* rotateX until revealed */
    --ry: 0deg;   /* rotateY set by pointer */
    --s: 0.985;   /* scale */
    opacity: 0;
    transform: translateY(var(--ty)) rotateX(var(--rx)) rotateY(var(--ry)) scale(var(--s));
    filter: blur(6px) saturate(.96);
    will-change: transform, opacity, filter;
    transition: transform 720ms cubic-bezier(.2,.95,.24,1), opacity 520ms ease, filter 520ms ease;
    transition-delay: var(--delay, 0ms);
    transform-origin: center;
    perspective: 1000px;
    backface-visibility: hidden;
  }

  .card.in-view {
    opacity: 1;
    --ty: 0px;
    --rx: 0deg;
    --s: 1;
    filter: blur(0) saturate(1);
  }

  /* Hover: small pop while keeping tilt variables intact */
  .card:hover { --s: 1.02; box-shadow: 0 18px 40px rgba(12,15,25,0.08); }

  /* Focus-visible for accessibility */
  .card:focus { outline: 2px solid rgba(34,197,94,0.12); outline-offset: 4px; }
</style>
