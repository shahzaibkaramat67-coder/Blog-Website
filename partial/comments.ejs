<!-- Comments Section -->
<div id="comments-container" class="max-w-4xl mx-auto bg-white shadow-lg rounded-lg mt-8 p-6">
  <h2 class="text-xl font-semibold mb-4">Comments</h2>

  <!-- Comment Form -->
  <form id="comments-form" class="mb-6 js-ajax">
    <input id="articalId" type="hidden" value="<%= articalById._id %>">
    <textarea id="commentText" placeholder="Write your comment..." class="w-full border p-3 rounded-lg mb-3"></textarea>
    <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-800">Post Comment</button>
  </form>

  <div id="comments-list"></div>
</div>
