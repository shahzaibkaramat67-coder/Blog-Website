<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %>
  </title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
  <header class="bg-white dark:bg-gray-900 shadow relative">
    <div class="mx-auto max-w-screen-xl pt-2 lg:px-8">
      <div class="flex h-16 items-center justify-between relative"> <!-- Left: Logo --> <a href="/home"
          class="flex items-center text-teal-600 dark:text-teal-400"> <svg class="h-8 w-8" fill="currentColor"
            viewBox="0 0 24 24">
            <path
              d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM11 17h2v-6h-2v6zm0-8h2V7h-2v2z" />
          </svg> <span class="ml-2 font-bold text-lg">MySite</span> </a> <!-- Mobile Menu Button -->
           <button
          id="nav-button" class="block md:hidden absolute right-4 top-4 rounded p-2 text-gray-700 dark:text-white z-50">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg> </button> <!-- Navigation -->
        <nav id="nav-item"
          class="hidden absolute mb-2 top-16 left-0 w-full bg-white dark:bg-gray-900 md:static md:flex md:items-center md:justify-between shadow-sm md:shadow-none z-50 transition-all duration-1000">
          <!-- Center: Main Links -->
          <ul
            class="flex flex-col md:flex-row items-start md:items-center gap-6 text-sm p-4 md:p-0 mx-auto font-medium">
            <li> <a href="/home"
                class="text-gray-700 dark:text-white hover:text-teal-600 transition-colors duration-200"> Home </a>
            </li> <!-- Categories Dropdown -->
            <li id="cat-button" class="group relative"> <a
                class="cursor-pointer text-gray-700 dark:text-white hover:text-teal-600 flex items-center gap-1">
                Categories <svg xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 mt-[2px] text-gray-500 group-hover:text-teal-600 transition" fill="none"
                  viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg> </a> <!-- Dropdown Menu -->
              <div id="cat-item"
                class="hidden  absolute md:fixed md:left-1/2 md:mt-6 md:w-[1300px] w-[60vw] md:-translate-x-1/2 bg-white dark:bg-gray-800 shadow-lg border dark:border-gray-700 rounded-lg p-4 grid grid-cols-1 md:grid-cols-5 gap-6 z-50 overflow-y-auto max-h-[80vh]">
                <% if (category && category.length) { %>
                  <% category.forEach(cat=> { %>
                    <div class="flex flex-col gap-2">
                      <h1 class="font-semibold text-base text-gray-800 dark:text-gray-200 border-b pb-1">
                        <%= cat.name %>
                      </h1>
                      <% if (cat.topics && cat.topics.length) { %>
                        <% cat.topics.forEach(topic=> { %>
                          <a href="/topics/<%= topic.slug %>"
                            class="text-gray-600 dark:text-gray-400 hover:text-teal-600 text-sm transition">
                            <%= topic.title %>
                          </a>
                          <% }) %>
                            <% } %>
                    </div>
                    <% }) %>
                      <% } %>
              </div>

            </li>
            <li><a href="/blog" class="text-gray-700 dark:text-white hover:text-teal-600">Blog</a></li>
            <li><a href="/about" class="text-gray-700 dark:text-white hover:text-teal-600">About</a></li>
            <li><a href="/contact" class="text-gray-700 dark:text-white hover:text-teal-600">Contact</a></li>
          </ul> <!-- Right: Auth Buttons -->
          <ul class="flex justify-start md:justify-end gap-3 mt-4 md:mt-0 md:pr-4">
            <% if (currentUser && currentUser.role==="user" ) { %>
              <div class="flex gap-3">
                 <a href="/profile" class="bg-teal-600 text-white px-4 py-2 rounded-md hover:bg-teal-500">Profile</a>
                  <a href="/logOut" class="bg-gray-100 text-teal-600 px-4 py-2 rounded-md dark:bg-gray-800 dark:text-white hover:bg-gray-200">Logout</a>
              </div>
              <% } else { %>
                <div class="flex gap-3"> 
                  <a href="./signup" class="bg-gray-100 text-teal-600 px-4 py-2 rounded-md dark:bg-gray-800 dark:text-white hover:bg-gray-200">Register</a>
                  <a href="/login"class="bg-gray-100 text-teal-600 px-4 py-2 rounded-md dark:bg-gray-800 dark:text-white hover:bg-gray-200">Login</a>
                </div>
                <% } %>
          </ul>
        </nav>
      </div>
    </div>
  </header>

</body>

</html>