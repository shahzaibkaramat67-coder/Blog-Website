<!-- Flash Messages Partial (Tailwind CSS) -->

<!-- Error Messages -->
<% if (error.length > 0) { %>
  <% error.forEach(msg => { %>
    <div class="mb-4 p-4 rounded-md bg-red-100 border border-red-400 text-red-700">
      <p><%= msg %></p>
    </div>
  <% }) %>
<% } %>

<!-- Success Messages -->
<% if (success.length > 0) { %>
  <% success.forEach(msg => { %>
    <div class="mb-4 p-4 rounded-md bg-green-100 border border-green-400 text-green-700">
      <p><%= msg %></p>
    </div>
  <% }) %>
<% } %>
